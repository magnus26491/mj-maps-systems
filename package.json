{
  "name": "mj-maps-systems",
  "version": "0.1.0",
  "description": "MJ Maps Systems — AI-powered delivery route intelligence platform",
  "main": "dist/api/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/services/db && cp -r services/db/migrations dist/services/db/migrations",
    "start": "node dist/api/index.js",
    "dev": "ts-node-dev --respawn --transpile-only api/index.ts",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node services/db/migrate.ts",
    "migrate:prod": "node dist/services/db/migrate.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3":        "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "open-location-code": "^1.0.3",
    "pg": "^8.11.5",
    "stripe": "^16.2.0",
    "twilio": "^5.2.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
