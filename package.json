{
  "name": "mj-maps-systems",
  "version": "0.1.0",
  "description": "MJ Maps Systems — AI-powered delivery route intelligence platform",
  "main": "dist/services/api/server.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/services/db && cp -r services/db/migrations dist/services/db/migrations && node scripts/validate-build.js",
    "start": "node dist/services/api/server.js",
    "dev": "ts-node-dev --respawn --transpile-only services/api/server.ts",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node services/db/migrate.ts",
    "migrate:prod": "node dist/services/db/migrate.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/compress": "^6.5.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@fastify/websocket": "^8.3.1",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "fastify": "^4.28.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "open-location-code": "^1.0.3",
    "pg": "^8.11.5",
    "stripe": "^16.2.0",
    "twilio": "^5.2.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.3.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.1",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json",
          "isolatedModules": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.js$": "$1"
    }
  }
}
