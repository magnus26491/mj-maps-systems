{
  "name": "@mj-maps/api",
  "version": "0.1.0",
  "description": "MJ Maps Systems — Driver API server (Fastify)",
  "main": "dist/server.js",
  "scripts": {
    "dev":   "tsx watch server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test":  "jest --passWithNoTests",
    "lint":  "eslint . --ext .ts"
  },
  "dependencies": {
    "@fastify/compress":   "^6.5.0",
