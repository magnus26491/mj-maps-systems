    "@fastify/jwt":        "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket":  "^8.3.1",
    "fastify":             "^4.28.1",
    "pino-pretty":         "^11.2.1",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "jest":        "^29.7.0",
    "ts-jest":     "^29.2.5",
    "tsx":         "^4.16.2",
    "typescript":  "^5.5.3"
