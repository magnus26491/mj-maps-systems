---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RouteLine from '../components/RouteLine.astro';
import TurnScoreDemo from '../components/TurnScoreDemo.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import PricingCards from '../components/PricingCards.astro';
import FAQ from '../components/FAQ.astro';
import HeroHUD from '../components/HeroHUD.astro';
import { photos } from '../assets/photos';
import { t } from '../i18n/index';
---

<BaseLayout
  title="MJ Maps — Delivery routing that knows your van"
  description="Turn-by-turn navigation for UK delivery drivers. Vehicle-aware routing, turn-score chips, exact gate-pin delivery — works fully offline."
  schema={{
    '@type': 'SoftwareApplication',
    name: 'MJ Maps',
    applicationCategory: 'NavigationApplication',
    operatingSystem: 'iOS, Android',
    offers: {
      '@type': 'Offer',
      price: '9.97',
      priceCurrency: 'GBP',
      availability: 'https://schema.org/InStock',
    },
  }}
>
  <Nav />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- HERO — editorial asymmetric: real road photo bg + HUD device      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section id="hero" class="hero-section" aria-labelledby="hero-heading">
      <!-- Full-bleed van dawn photo (eager — LCP element) -->
      <img
        src={photos.heroVanDawn}
        alt="White box van on a foggy UK rural lane at dawn — MJ Maps navigation"
        class="hero-photo"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      />
      <!-- Dark left scrim: text readable on left, photo bleeds through on right -->
      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="container hero-inner">
        <!-- Left: bold editorial text column -->
        <div class="hero-text">
          <!-- Eyebrow: live signal chip + coords -->
          <div class="hero-eyebrow reveal">
            <span class="chip chip-brand">
              <svg width="8" height="8" viewBox="0 0 8 8" aria-hidden="true"><circle cx="4" cy="4" r="4" fill="currentColor"/></svg>
              {t('hero.eyebrowLabel')}
            </span>
            <span class="font-mono hero-coords">{t('hero.coords')}</span>
          </div>

          <!-- Headline -->
          <h1 id="hero-heading" class="reveal" data-delay="80">
            {t('hero.headline').split('\n').map((line: string) => (
              <>{line}{line !== t('hero.headline').split('\n').at(-1) && <br/>}</>
            ))}
          </h1>

          <!-- Subheadline -->
          <p class="hero-sub reveal" data-delay="160">{t('hero.sub')}</p>

          <!-- CTAs -->
          <div class="hero-ctas reveal" data-delay="240">
            <a href="/register?plan=navigation" class="btn btn-primary hero-cta-primary">
              {t('hero.ctaPrimary')}
            </a>
            <a href="/features" class="btn btn-secondary">{t('hero.ctaSecondary')}</a>
          </div>

          <!-- Trust signals -->
          <div class="hero-trust reveal" data-delay="320">
            <span class="trust-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M11.5 3.5L5.5 9.5 2.5 6.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {t('hero.trustCancel')}
            </span>
            <span class="trust-sep" aria-hidden="true">·</span>
            <span class="trust-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M11.5 3.5L5.5 9.5 2.5 6.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {t('hero.trustNoRenew')}
            </span>
            <span class="trust-sep" aria-hidden="true">·</span>
            <span class="trust-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M11.5 3.5L5.5 9.5 2.5 6.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {t('hero.trustOffline')}
            </span>
          </div>
        </div>

        <!-- Right: live HUD card with real photo background -->
        <div class="hero-device-wrap reveal" data-delay="160">
          <HeroHUD score="green" />
        </div>
      </div>

      <!-- Scroll cue -->
      <div class="hero-scroll-cue" aria-hidden="true">
        <span class="font-mono">Scroll</span>
        <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
          <rect x="1" y="1" width="14" height="18" rx="7" stroke="#64748B" stroke-width="1.5"/>
          <circle cx="8" cy="6" r="2" fill="#64748B" class="scroll-dot"/>
        </svg>
      </div>
    </section>

    <script>
      // ── Hero parallax ──────────────────────────────────────────────────
      (function () {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return;
        const heroPhoto = document.querySelector<HTMLImageElement>('.hero-photo');
        if (!heroPhoto) return;
        function onScroll() {
          const scrolled = window.scrollY;
          heroPhoto!.style.transform = `translateY(${scrolled * 0.30}px)`;
        }
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TRUST BAR                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="trust-bar-section" aria-label="Trust signals">
      <div class="container">
        <div class="trust-bar-inner reveal">
          <div class="trust-item-pair">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="16" height="16" rx="4" stroke="#00C2A8" stroke-width="1.5"/>
              <path d="M6 10 L9 13 L14 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{t("trustBar.ukFounded")}</span>
          </div>
          <div class="trust-divider" aria-hidden="true"></div>
          <div class="trust-item-pair">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 2 L12 7 H18 L13 11 L15 17 L10 13 L5 17 L7 11 L2 7 H8 Z" stroke="#00C2A8" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            <span>{t("trustBar.ukGdpr")}</span>
          </div>
          <div class="trust-divider" aria-hidden="true"></div>
          <div class="trust-item-pair">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="8" stroke="#00C2A8" stroke-width="1.5"/>
              <path d="M6 10 L9 13 L14 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{t("trustBar.fourteenDayTrial")}</span>
          </div>
          <div class="trust-divider" aria-hidden="true"></div>
          <div class="trust-item-pair">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M3 14 L7 10 L10 13 L14 8 L17 11" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="10" cy="5" r="2" fill="#00C2A8"/>
            </svg>
            <span>{t("trustBar.worksOffline")}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BEFORE/AFTER SLIDER                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="ba-section" aria-labelledby="ba-heading">
      <div class="container">
        <div class="ba-layout">
          <div class="ba-text">
            <h2 id="ba-heading" class="reveal" data-delay="80">
              {t('beforeAfter.headline').split('\n').map((line: string) => (
                <>{line}{line !== t('beforeAfter.headline').split('\n').at(-1) && <br/>}</>
              ))}
            </h2>
            <p class="ba-sub reveal" data-delay="160">{t('beforeAfter.sub')}</p>
            <div class="ba-tags reveal" data-delay="240">
              <span class="chip chip-brand">{t('beforeAfter.tagPlusCodes')}</span>
              <span class="chip chip-brand">{t('beforeAfter.tagGatePins')}</span>
              <span class="chip chip-brand">{t('beforeAfter.tagCommunity')}</span>
            </div>
          </div>
          <div class="ba-slider-wrap reveal" data-delay="120">
            <BeforeAfterSlider
              beforeSrc="/img/maps/before-postcode-centroid.svg"
              afterSrc="/img/maps/after-gate-pin.svg"
              beforeLabel={t('beforeAfter.beforeLabel')}
              afterLabel={t('beforeAfter.afterLabel')}
              initialPosition={45}
            />
            <p class="ba-hint mono">{t('beforeAfter.hint')}</p>
            <!-- Supporting driver-at-gate photo -->
            <figure class="ba-supporting-photo reveal" data-delay="200">
              <img
                src={photos.gatePinDelivery}
                alt="Driver in hi-vis at a UK farm gate with phone showing exact Plus Code delivery pin"
                width="600"
                height="338"
                loading="lazy"
                decoding="async"
              />
              <figcaption class="mono">
                Driver at the gate — pin within 2 metres, no need to ask
              </figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TURN SCORE DEMO                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section
      class="ts-section"
      aria-labelledby="ts-heading"
      style={`background-image: linear-gradient(to right, rgba(10,12,16,0.96) 0%, rgba(10,12,16,0.80) 50%, rgba(10,12,16,0.55) 100%), url('${photos.turnScoreNight}')`}
    >
      <div class="container">
        <div class="ts-layout">
          <div class="ts-demo-wrap reveal">
            <TurnScoreDemo autoCycle={true} initialState="green" />
          </div>
          <div class="ts-text">
            <h2 id="ts-heading" class="reveal" data-delay="80">
              {t('turnScore.headline').split('\n').map((l: string) => (
                <>{l}{l !== t('turnScore.headline').split('\n').at(-1) && <br/>}
              </>))}
            </h2>
            <p class="reveal" data-delay="160">{t('turnScore.sub1')}</p>
            <p class="reveal" data-delay="220">{t('turnScore.sub2')}</p>
            <a href="/features" class="btn btn-secondary reveal" data-delay="280">
              {t('turnScore.cta')}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FEATURE GRID                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <FeatureGrid />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- PRICING PREVIEW                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="pricing-preview-section below-fold" aria-labelledby="pricing-heading">
      <div class="container">
        <h2 id="pricing-heading" class="reveal" data-delay="60">{t("pricing.headline")}</h2>
        <p class="section-sub reveal" data-delay="120">{t('pricing.sub')}</p>

        <div class="pricing-cards-grid reveal" data-delay="200">
          <!-- Driver Pro -->
          <div class="pricing-card pricing-card-featured card">
            <div class="pricing-card-header">
              <span class="chip chip-brand">{t("pricing.popular")}</span>
              <h3 class="pricing-plan-name">{t("pricing.driverPro")}</h3>
              <p class="pricing-tagline">{t("pricing.driverProTag")}</p>
            </div>
            <div class="pricing-price-block">
              <div class="pricing-price">
                <span class="pricing-currency font-display">£</span>
                <span class="pricing-amount font-display">9.97</span>
                <span class="pricing-period font-mono">/mo</span>
              </div>
              <p class="pricing-vat-note mono">{t('pricing.vatYear')}</p>
            </div>
            <ul class="pricing-features" aria-label="Driver Pro features">
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Vehicle-aware routing (height, weight, width)
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Turn-score on every junction
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Gate-pin delivery + Plus Codes
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Fully offline maps
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Route optimisation
              </li>
            </ul>
            <a href="/register?plan=navigation" class="btn btn-primary btn-full">
              Start free trial
            </a>
            <p class="pricing-cancel-note mono">{t('pricing.cancelNote')}</p>
          </div>

          <!-- Enterprise -->
          <div class="pricing-card card">
            <div class="pricing-card-header">
              <h3 class="pricing-plan-name">{t("pricing.enterprise")}</h3>
              <p class="pricing-tagline">{t("pricing.enterpriseTag")}</p>
            </div>
            <div class="pricing-price-block">
              <div class="pricing-price">
                <span class="pricing-amount font-display">Custom</span>
              </div>
              <p class="pricing-vat-note mono">{t('pricing.vatEnterprise')}</p>
            </div>
            <ul class="pricing-features" aria-label="Enterprise features">
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Everything in Driver Pro
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Dispatcher dashboard + live fleet tracking
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                POD capture + admin analytics
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Multi-depot, route assignment, fleet tracking
              </li>
              <li class="pricing-feature">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13 3L6 10 3 7" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Priority support + onboarding
              </li>
            </ul>
            <a href="/contact" class="btn btn-secondary btn-full">
              Talk to us
            </a>
          </div>
        </div>

        <div class="pricing-compare-link reveal" data-delay="300">
          <a href="/pricing">Compare all features →</a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FOUNDER STORY                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section
      class="founder-section below-fold"
      aria-labelledby="founder-heading"
      style={`background-image: linear-gradient(to right, rgba(10,12,16,0.97) 0%, rgba(10,12,16,0.88) 40%, rgba(10,12,16,0.55) 65%, rgba(10,12,16,0.40) 80%, transparent 100%), url('${photos.fleetRouting}')`}
    >
      <div class="container">
        <div class="founder-inner">
          <div class="founder-quote-col reveal" data-delay="80">
            <div class="founder-quote-card">
              <svg class="quote-mark" viewBox="0 0 40 30" fill="none" aria-hidden="true">
                <path d="M0 30V18C0 10.3 4.2 4.3 12.6 0L16 4.2C10.8 6.8 8.2 10.8 8.2 16H16V30H0ZM24 30V18C24 10.3 28.2 4.3 36.6 0L40 4.2C34.8 6.8 32.2 10.8 32.2 16H40V30H24Z" fill="currentColor"/>
              </svg>
              <blockquote class="founder-quote">
                We spent three years doing rural parcel deliveries before building MJ Maps.
                Every wrong turn, every low bridge, every gate we couldn't find —
                we encoded that knowledge into the routing engine.
              </blockquote>
              <p class="founder-attr">
                <span class="founder-name">MJ Maps founders</span>
                <span class="founder-role">UK delivery drivers, 2019–2022</span>
              </p>
            </div>
          </div>

          <div class="founder-facts-col reveal" data-delay="160">
            <h3 class="founder-facts-heading">What we can tell you honestly</h3>
            <ul class="founder-facts-list">
              <li>
                <span class="fact-badge chip chip-green">14 days</span>
                Free trial. No card required.
              </li>
              <li>
                <span class="fact-badge chip chip-brand">£9.97 / mo</span>
                Driver Pro, billed monthly, VAT included.
              </li>
              <li>
                <span class="fact-badge chip chip-brand">Cancel anytime</span>
                No auto-renew, no cancellation fees.
              </li>
              <li>
                <span class="fact-badge chip chip-brand">Offline-first</span>
                Core navigation works without signal.
              </li>
              <li>
                <span class="fact-badge chip chip-brand">UK GDPR</span>
                Location data used only for navigation, never sold.
              </li>
            </ul>
            <div class="founder-link">
              <a href="/about" class="btn btn-secondary">Our story →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FAQ                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <FAQ />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- FINAL CTA                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <section class="final-cta-section below-fold" aria-labelledby="final-cta-heading">
      <div class="container">
        <div class="final-cta-inner">
          <div class="final-cta-routeline" aria-hidden="true">
            <RouteLine score="teal" animated={false} viewBox="0 0 400 60" />
          </div>
          <h2 id="final-cta-heading" class="reveal">
            Stop guessing the last 50 metres
          </h2>
          <p class="final-cta-sub reveal" data-delay="80">{t('finalCta.sub')}</p>
          <div class="final-cta-btns reveal" data-delay="160">
            <a href="/register?plan=navigation" class="btn btn-primary">{t('finalCta.cta')}</a>
            <a href="/contact" class="btn btn-secondary">{t('finalCta.ctaSecondary')}</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════════ */
  /* HERO                                                              */
  /* ═══════════════════════════════════════════════════════════════════ */

  .hero-section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-block: 120px 80px;
    overflow: hidden;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    z-index: 0;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(10, 12, 16, 0.97) 0%,
      rgba(10, 12, 16, 0.78) 30%,
      rgba(10, 12, 16, 0.40) 52%,
      transparent 72%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      flex-direction: row;
      gap: 64px;
      align-items: flex-start;
      padding-top: 40px;
    }
  }

  .hero-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .hero-text {
      text-align: left;
      margin-inline: 0;
      padding-top: 24px;
    }
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (min-width: 1024px) {
    .hero-eyebrow { justify-content: flex-start; }
  }

  .hero-coords {
    color: var(--ink-faint);
    font-size: 0.75rem;
  }

  #hero-heading {
    margin-bottom: 16px;
    text-align: center;
  }

  @media (min-width: 1024px) {
    #hero-heading { text-align: left; }
  }

  .hero-sub {
    color: var(--ink-muted);
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 480px;
    margin-inline: auto;
    margin-bottom: 28px;
    text-align: center;
  }

  @media (min-width: 1024px) {
    .hero-sub { margin-inline: 0; text-align: left; }
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-ctas { justify-content: flex-start; }
  }

  .hero-cta-primary {
    height: 52px;
    padding: 0 28px;
    font-size: 1rem;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-trust { justify-content: flex-start; }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--ink-muted);
    font-size: 0.875rem;
  }

  .trust-sep {
