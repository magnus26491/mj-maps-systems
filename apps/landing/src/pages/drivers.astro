---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import { type FeatureKey } from '@plans';

const driverKeys: FeatureKey[] = [
  'NAVIGATION', 'HGV_ROUTING', 'BRIDGE_RESTRICTIONS', 'TURN_SCORE',
  'UNPAVED_SCORING', 'OFFLINE_CACHE', 'W3W_PIN', 'LIVE_TRAFFIC',
  'ROADWORKS_AVOIDANCE', 'TIME_AWARE_OPTIMIZER', 'PARKING_ADVISORY',
  'TIDAL_AVOIDANCE',
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://mjmapsystems.com' },
    { '@type': 'ListItem', position: 2, name: 'For Drivers', item: 'https://mjmapsystems.com/drivers' },
  ],
};
---

<BaseLayout
  title="For Drivers — MJ Maps: UK Delivery Navigation App"
  description="MJ Maps for solo delivery drivers. HGV routing, bridge alerts, turn-score warnings, exact gate pins, full offline mode. Free trial, no card needed. iOS & Android."
  schema={breadcrumb}
>
  <Nav activePage="/drivers" />
  <main id="main-content">
    <div class="page-hero">
      <div class="container">
        <div class="chip chip-green hero-chip reveal">For Drivers</div>
        <h1 class="reveal">Navigate like you know every road — because now you will.</h1>
        <p class="page-hero-sub reveal">Vehicle-aware routing, turn-score warnings, last-50m gate pins, and full offline mode. Built for UK delivery drivers who can't afford wrong turns.</p>
        <div class="hero-ctas reveal">
          <a href="/register?plan=navigation" class="btn btn-primary">Start free trial — no card needed</a>
          <a href="/features" class="btn btn-secondary">See all features →</a>
        </div>
        <div class="hero-badges reveal">
          <a href="/register?plan=navigation" aria-label="Download on the App Store" class="badge-link">
            <svg width="140" height="44" viewBox="0 0 140 44" fill="none" aria-hidden="true">
              <rect width="140" height="44" rx="9" fill="#111827" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
              <text x="40" y="16" fill="#9CA3AF" font-size="7.5" font-family="Inter,sans-serif">Download on the</text>
              <text x="40" y="31" fill="#F9FAFB" font-size="14" font-family="Space Grotesk,sans-serif" font-weight="700">App Store</text>
              <path d="M20 22 C20 17 24 13 29 13 C31 13 33 14 34 15 C35 14 37 13 39 13 C44 13 48 17 48 22 C48 28 43 33 34 37 C25 33 20 28 20 22Z" fill="none" stroke="#00C2A8" stroke-width="1.5"/>
            </svg>
          </a>
          <a href="/register?plan=navigation" aria-label="Get it on Google Play" class="badge-link">
            <svg width="140" height="44" viewBox="0 0 140 44" fill="none" aria-hidden="true">
              <rect width="140" height="44" rx="9" fill="#111827" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
              <text x="40" y="16" fill="#9CA3AF" font-size="7.5" font-family="Inter,sans-serif">Get it on</text>
              <text x="40" y="31" fill="#F9FAFB" font-size="14" font-family="Space Grotesk,sans-serif" font-weight="700">Google Play</text>
              <polygon points="22,13 22,31 34,22" fill="none" stroke="#00C2A8" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <p class="hero-note reveal">Free 14-day trial · No credit card · Cancel anytime</p>
      </div>
    </div>

    <!-- Trust strip -->
    <section class="trust-strip" aria-label="Key facts">
      <div class="container">
        <div class="trust-bar glass reveal">
          {[
            { stat: 'UK GDPR', label: 'compliant — location data never sold' },
            { stat: 'Full offline', label: 'mode — works with zero signal' },
            { stat: '300m', label: 'bridge alert lead time' },
            { stat: 'No auto-renew', label: '— cancel any month' },
          ].map(t => (
            <div class="trust-item">
              <span class="trust-stat">{t.stat}</span>
              <span class="trust-label text-muted">{t.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FeatureGrid
      title="Driver features"
      subtitle="Everything included in Driver Pro — all in one app, offline-capable."
      featureKeys={driverKeys}
    />

    <!-- Driver workflow -->
    <section class="driver-workflow below-fold">
      <div class="container">
        <h2 class="reveal">A shift in your pocket</h2>
        <div class="workflow-grid">
          <div class="workflow-item reveal">
            <div class="workflow-step mono">6:00</div>
            <h3>Load your stops</h3>
            <p class="text-muted">Paste your manifest or import from your depot system. MJ Maps pins each stop to the exact gate — not the postcode centre.</p>
          </div>
          <div class="workflow-item reveal">
            <div class="workflow-step mono">6:05</div>
            <h3>Route optimises for your van</h3>
            <p class="text-muted">Select your vehicle profile. The engine scores every turn for your specific weight and height, then optimises the stop sequence.</p>
          </div>
          <div class="workflow-item reveal">
            <div class="workflow-step mono">All day</div>
            <h3>Drive with confidence</h3>
            <p class="text-muted">Turn-score chips tell you what to expect at every junction. Bridge alerts fire 300m early. Rerouting kicks in automatically if you deviate.</p>
          </div>
          <div class="workflow-item reveal">
            <div class="workflow-step mono">Each stop</div>
            <h3>Confirm delivery</h3>
            <p class="text-muted">Scan the barcode, take a photo, capture a signature. One tap marks delivered and advances to the next stop.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Driver CTA -->
    <section class="driver-cta below-fold">
      <div class="container">
        <div class="driver-cta-inner glass reveal">
          <h2>Try it on your next shift</h2>
          <p class="text-muted">Free trial, no card required. Install the app, set up your profile, and route your first shift in under 5 minutes.</p>
          <a href="/register?plan=navigation" class="btn btn-primary">Start free trial</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding-block: 120px 48px;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0,194,168,0.06) 0%, transparent 60%), var(--void);
    text-align: center;
  }
  .hero-chip { margin-bottom: 16px; display: inline-flex; }
  .page-hero-sub {
    color: var(--ink-muted);
    font-size: 1.125rem;
    margin-top: 12px;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: 24px;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }
  .badge-link { opacity: 0.85; transition: opacity var(--dur-micro) ease-out; text-decoration: none; }
  @media (hover: hover) { .badge-link:hover { opacity: 1; } }
  .hero-note { font-size: 0.8125rem; color: var(--ink-faint); margin-top: 16px; }

  /* Trust strip */
  .trust-strip { padding-block: 32px; }
  .trust-bar {
    border-radius: var(--r-card);
    padding: 24px 32px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px 32px;
  }
  @media (min-width: 768px) { .trust-bar { grid-template-columns: repeat(4, 1fr); } }
  .trust-item { display: flex; flex-direction: column; gap: 4px; }
  .trust-stat { font-size: 1rem; font-weight: 700; color: var(--brand-bright); }
  .trust-label { font-size: 0.8125rem; line-height: 1.4; }

  .workflow-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 40px;
  }
  @media (min-width: 640px) { .workflow-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .workflow-grid { grid-template-columns: repeat(4, 1fr); } }

  .workflow-item {
    background: var(--surface);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-card);
    padding: 24px;
  }
  .workflow-step {
    font-size: 0.875rem;
    color: var(--brand-bright);
    margin-bottom: 12px;
  }
  .workflow-item h3 { margin-bottom: 8px; }

  .driver-cta { padding-block: var(--section-py); }
  .driver-cta-inner {
    border-radius: var(--r-panel);
    padding: 48px 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .driver-cta-inner p { max-width: 480px; }
</style>
