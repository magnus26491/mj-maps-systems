---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PricingCards from '../components/PricingCards.astro';
import { t } from '../i18n/index';
import FAQ from '../components/FAQ.astro';
import { PLAN_FEATURES, FEATURE_META, PLAN_META, PRICES, type PlanId, type FeatureKey } from '@plans';

// Build full feature comparison table
const allFeatureKeys: FeatureKey[] = [
  'NAVIGATION', 'HGV_ROUTING', 'BRIDGE_RESTRICTIONS', 'LIVE_TRAFFIC',
  'ROADWORKS_AVOIDANCE', 'TIME_AWARE_OPTIMIZER', 'OFFLINE_CACHE',
  'PARKING_ADVISORY', 'TIDAL_AVOIDANCE', 'UNPAVED_SCORING',
  'TURN_SCORE', 'W3W_PIN',
  'ROUTE_OPTIMISE', 'STOP_MANAGEMENT', 'PIN_CONFIRM', 'ACCESS_NOTES',
  'FAILED_DELIVERY', 'STOP_STATUS', 'ETA_NOTIFICATIONS',
  'BARCODE_SCANNING', 'POD_PHOTO', 'SIGNATURE_CAPTURE',
  'DISPATCHER', 'LIVE_TRACKING_WS', 'WORKLOAD_GUARD',
  'TROLLEY_ADVISORY', 'ROUTE_INTEL', 'RED_ALERTS', 'ADMIN_ANALYTICS',
];

const plans: PlanId[] = ['navigation', 'custom'];
---

<BaseLayout
  title="Pricing — MJ Maps"
  description="Simple, honest pricing for MJ Maps. Driver Pro at £9.97/mo. Enterprise with custom pricing. No auto-renew, cancel anytime."
>
  <Nav activePage="/pricing" />
  <main id="main-content">
    <div class="page-hero">
      <div class="container">
        <h1 class="reveal">Simple, honest pricing</h1>
        <p class="page-hero-sub reveal">Driver Pro for solo drivers. Enterprise for fleet operators. All prices include VAT. Cancel any time — no auto-renew, no cancellation fees.</p>
        <div class="page-hero-trust reveal" data-delay="80">
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11.5 3.5L5.5 9.5 2.5 6.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            14-day free trial
          </span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11.5 3.5L5.5 9.5 2.5 6.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            No card required to start
          </span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span class="trust-item">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M11.5 3.5L5.5 9.5 2.5 6.5" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Cancel anytime
          </span>
        </div>
      </div>
    </div>

    <PricingCards />

    <!-- Full feature comparison table -->
    <section class="compare-section below-fold" aria-labelledby="compare-heading">
      <div class="container">
        <h2 id="compare-heading" class="reveal">Full feature comparison</h2>

        <!-- Sticky plan header bar -->
        <div class="compare-header-bar reveal">
          <div class="compare-header-feature-col">Feature</div>
          {plans.map(p => {
            const meta = PLAN_META[p];
            const prices = PRICES[p];
            return (
              <div class={`compare-header-plan ${p === 'navigation' ? 'compare-header-plan--pro' : 'compare-header-plan--ent'}`}>
                {meta.badge && <div class="compare-plan-badge">{meta.badge}</div>}
                <div class="compare-plan-name">{meta.displayName}</div>
                <div class="compare-plan-price">
                  {prices.GBP.monthly === null ? (
                    <span class="compare-plan-custom">Custom</span>
                  ) : (
                    <>
                      <span class="compare-plan-amount">£{prices.GBP.monthly.toFixed(2)}</span>
                      <span class="compare-plan-period">/mo</span>
                    </>
                  )}
                </div>
                {p === 'navigation' && (
                  <div class="compare-plan-tagline">Solo &amp; small-team drivers</div>
                )}
                {p === 'custom' && (
                  <div class="compare-plan-tagline">Fleet &amp; operations teams</div>
                )}
              </div>
            );
          })}
        </div>

        <div class="compare-table-wrap reveal">
          <table class="compare-table">
            <thead class="sr-only">
              <tr>
                <th scope="col">Feature</th>
                <th scope="col">Driver Pro</th>
                <th scope="col">Enterprise</th>
              </tr>
            </thead>
            <tbody>
              {allFeatureKeys.map(key => {
                const meta = FEATURE_META[key];
                const inPro = (PLAN_FEATURES['navigation'] as readonly string[]).includes(key);
                const inEnt = (PLAN_FEATURES['custom'] as readonly string[]).includes(key);
                const isNew = inEnt && !inPro;
                return (
                  <tr class={`compare-row${isNew ? ' compare-row--new' : ''}`}>
                    <td class="feature-name">
                      {meta.label}
                      {meta.comingSoon && <span class="chip chip-brand chip-sm ml-8">Soon</span>}
                      {isNew && <span class="chip chip-brand chip-sm ml-4">Enterprise only</span>}
                    </td>
                    <td class={`plan-cell ${inPro ? 'has-feature' : 'no-feature'}`} aria-label={inPro ? 'Included in Driver Pro' : 'Not included'}>
                      {inPro ? (
                        <svg class="check-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                          <circle cx="11" cy="11" r="10" fill="rgba(0,194,168,0.15)" stroke="rgba(0,194,168,0.3)" stroke-width="1"/>
                          <path d="M7 11l3 3 5-5" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      ) : (
                        <span class="no-feature-dash" aria-hidden="true">—</span>
                      )}
                    </td>
                    <td class={`plan-cell ${inEnt ? 'has-feature' : 'no-feature'}`} aria-label={inEnt ? 'Included in Enterprise' : 'Not included'}>
                      {inEnt ? (
                        <svg class="check-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                          <circle cx="11" cy="11" r="10" fill="rgba(0,194,168,0.15)" stroke="rgba(0,194,168,0.3)" stroke-width="1"/>
                          <path d="M7 11l3 3 5-5" stroke="#00C2A8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      ) : (
                        <span class="no-feature-dash" aria-hidden="true">—</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <div class="compare-footer reveal">
          <p class="compare-footer-note">
            All prices include VAT. Enterprise pricing tailored to fleet size — <a href="/contact">talk to us</a>.
            Driver Pro: 14-day free trial, cancel anytime, no auto-renew.
          </p>
        </div>
      </div>
    </section>

    <FAQ />
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding-block: 120px 64px;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0,194,168,0.06) 0%, transparent 60%), var(--void);
    text-align: center;
  }

  .page-hero-sub {
    color: var(--ink-muted);
    font-size: 1.125rem;
    margin-top: 12px;
    max-width: 520px;
    margin-inline: auto;
    margin-bottom: 20px;
  }

  .page-hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 16px;
    justify-content: center;
    align-items: center;
    font-size: 0.875rem;
    color: var(--ink-muted);
  }

  .page-hero-trust .trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .page-hero-trust .trust-sep {
    color: var(--ink-faint);
  }

  .compare-section h2 {
    text-align: center;
    margin-bottom: 32px;
  }

  /* ── Sticky plan header bar ──────────────────────────────────────── */
  .compare-header-bar {
    display: grid;
    grid-template-columns: 1fr repeat(2, 180px);
    gap: 0;
    margin-bottom: 0;
    border: 1px solid var(--glass-brd);
    border-bottom: none;
    border-radius: var(--r-lg) var(--r-lg) 0 0;
    overflow: hidden;
    background: var(--surface);
  }

  .compare-header-feature-col {
    padding: 20px 20px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--surface-1);
    display: flex;
    align-items: flex-end;
  }

  .compare-header-plan {
    padding: 20px;
    text-align: center;
    position: relative;
    border-left: 1px solid var(--glass-brd);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .compare-header-plan--pro {
    background: linear-gradient(180deg, rgba(0,194,168,0.06) 0%, var(--surface) 100%);
  }

  .compare-header-plan--ent {
    background: linear-gradient(180deg, rgba(59,130,246,0.04) 0%, var(--surface) 100%);
  }

  .compare-plan-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #000;
    background: var(--brand);
    padding: 2px 10px;
    border-radius: var(--r-pill);
    margin-bottom: 4px;
  }

  .compare-plan-name {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
  }

  .compare-plan-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .compare-plan-amount {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
  }

  .compare-plan-period {
    font-size: 0.8125rem;
    color: var(--ink-muted);
  }

  .compare-plan-custom {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink-muted);
  }

  .compare-plan-tagline {
    font-size: 0.6875rem;
    color: var(--ink-faint);
    margin-top: 2px;
  }

  /* ── Table ───────────────────────────────────────────────────────── */
  .compare-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--glass-brd);
    border-top: none;
    border-radius: 0 0 var(--r-lg) var(--r-lg);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    min-width: 540px;
  }

  .compare-row {
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background var(--dur-micro) ease-out;
  }

  @media (hover: hover) {
    .compare-row:hover {
      background: rgba(255,255,255,0.025);
    }
  }

  .compare-row--new {
    background: rgba(59, 130, 246, 0.04);
  }

  .compare-row--new:hover {
    background: rgba(59, 130, 246, 0.07) !important;
  }

  .feature-name {
    padding: 13px 20px;
    color: var(--ink-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .plan-cell {
    text-align: center;
    padding: 13px 20px;
    vertical-align: middle;
  }

  .check-icon {
    display: inline-block;
    vertical-align: middle;
  }

  .no-feature-dash {
    color: var(--ink-faint);
    font-size: 1.25rem;
  }

  /* ── Footer note ─────────────────────────────────────────────────── */
  .compare-footer {
    margin-top: 20px;
    text-align: center;
  }

  .compare-footer-note {
    font-size: 0.875rem;
    color: var(--ink-faint);
  }

  .compare-footer-note a {
    color: var(--brand);
    text-decoration: none;
  }

  .compare-footer-note a:hover {
    color: var(--brand-bright);
  }

  /* ── Chip size variant ───────────────────────────────────────────── */
  .chip-sm {
    font-size: 0.625rem;
    padding: 1px 6px;
    border-radius: var(--r-pill);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .ml-4 { margin-left: 4px; }
  .ml-8 { margin-left: 8px; }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .compare-header-bar {
      grid-template-columns: 1fr repeat(2, 140px);
    }
    .compare-header-plan { padding: 14px 12px; }
    .compare-plan-amount { font-size: 1.25rem; }
  }
</style>
