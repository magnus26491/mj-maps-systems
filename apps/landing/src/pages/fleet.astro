---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import { type FeatureKey } from '@plans';
import { t } from '../i18n/index';

const fleetKeys: FeatureKey[] = [
  'DISPATCHER', 'LIVE_TRACKING_WS', 'RED_ALERTS', 'ROUTE_INTEL',
  'ADMIN_ANALYTICS', 'WORKLOAD_GUARD', 'POD_PHOTO', 'SIGNATURE_CAPTURE',
  'ETA_NOTIFICATIONS', 'STOP_STATUS', 'FAILED_DELIVERY', 'TROLLEY_ADVISORY',
];
---

<BaseLayout
  title="For Fleets — MJ Maps Enterprise"
  description="MJ Maps Enterprise for fleet operations. Live dispatcher console, real-time tracking, POD photo capture, signature collection, and exception alerts."
>
  <Nav activePage="/fleet" />
  <main id="main-content">
    <div class="page-hero">
      <!-- Full-bleed fleet routing visualisation -->
      <picture>
        <source srcset="/img/photos/fleet-routing.webp" type="image/webp" />
        <img
          src="/img/photos/fleet-routing.png"
          alt="Fleet routing visualisation — 3 vans with live routes on a dispatcher map"
          class="hero-photo"
          loading="eager"
          fetchpriority="high"
          width="1600"
          height="900"
        />
      </picture>
      <div class="hero-scrim" aria-hidden="true"></div>
      <div class="container">
        <div class="chip chip-brand hero-chip reveal">Enterprise</div>
        <h1 class="reveal">Fleet-grade control for operations teams</h1>
        <p class="page-hero-sub reveal">From the dispatcher console to the driver's screen — full visibility, instant alerts, and proof of every delivery.</p>
        <div class="hero-ctas reveal">
          <a href="/contact" class="btn btn-primary">Book a fleet demo</a>
          <a href="/pricing" class="btn btn-secondary">Compare plans</a>
        </div>
      </div>
    </div>

    <!-- Dispatcher preview -->
    <section class="dispatcher-preview below-fold">
      <div class="container">
        <div class="dp-inner">
          <div class="dp-text reveal">
            <h2>Live fleet map — under 5 seconds</h2>
            <p class="text-muted">Every driver's location updates via WebSocket. You see the entire fleet on one map, with stop progress and exception flags, in near real-time.</p>
            <ul class="dp-list">
              <li>Driver positions update every 2–5 seconds</li>
              <li>Completed, in-progress, and failed stops colour-coded</li>
              <li>Click any driver to see their active route and ETA</li>
              <li>Instant Telegram alert on off-route or long dwell</li>
            </ul>
          </div>
          <div class="dp-mockup reveal">
            <div class="dp-panel glass">
              <div class="dp-header">
                <span class="dp-title">Fleet Overview</span>
                <span class="chip chip-green">● Live</span>
              </div>
              <div class="dp-drivers">
                {[
                  { name: 'Driver 1', stops: '12/18', status: 'green', eta: '14:22' },
                  { name: 'Driver 2', stops: '7/14',  status: 'amber', eta: '16:05' },
                  { name: 'Driver 3', stops: '18/18', status: 'green', eta: 'Done' },
                ].map(d => (
                  <div class="dp-driver-row">
                    <div class={`dp-driver-dot chip-${d.status}`} aria-hidden="true"></div>
                    <span class="dp-driver-name">{d.name}</span>
                    <span class="mono dp-driver-stops text-muted">{d.stops} stops</span>
                    <span class="mono dp-driver-eta">ETA {d.eta}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <FeatureGrid
      title="Enterprise features"
      subtitle="Everything in Driver Pro, plus fleet-level visibility and proof of delivery."
      featureKeys={fleetKeys}
    />

    <!-- Compliance strip -->
    <section class="compliance-strip below-fold" aria-label="Data and compliance">
      <div class="container">
        <div class="compliance-inner glass reveal">
          <h2 class="compliance-heading">Data stays yours. Always.</h2>
          <div class="compliance-grid">
            {[
              {
                title: 'UK GDPR compliant',
                body: 'Registered UK data controller. Location data is collected only during active shifts and never sold or shared with third parties.',
                svg: '<path d="M7 10.5l2 2 4-4" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><rect x="3" y="5" width="8" height="7" rx="1.5" stroke="#00C2A8" stroke-width="1.5"/>'
              },
              {
                title: 'Data portability',
                body: 'Export your routes, stops, and POD records any time in CSV or JSON. Cancel any month — no data held hostage.',
                svg: '<path d="M8 3v8M5 8l3 3 3-3" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M3 11v2a2 2 0 002 2h6a2 2 0 002-2v-2" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" fill="none"/>'
              },
              {
                title: 'TLS in transit',
                body: 'All API traffic is encrypted. Driver locations are transmitted over authenticated WebSocket and stored with row-level access control.',
                svg: '<path d="M8 2l6 6-6 6" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M2 6l6 6-6 6" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M14 10H8M10 8v4" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round"/>'
              },
              {
                title: 'Privacy by design',
                body: 'Driver location is used for routing and shift reporting only. No advertising profiling. Full details in our Privacy Policy.',
                svg: '<rect x="3" y="3" width="8" height="6" rx="1" stroke="#00C2A8" stroke-width="1.5" fill="none"/><path d="M3 9h8M6 9v5" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round"/>'
              },
            ].map(item => (
              <div class="compliance-card">
                <div class="compliance-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" set:html={item.svg}/>
                </div>
                <h3 class="compliance-title">{item.title}</h3>
                <p class="compliance-body text-muted">{item.body}</p>
              </div>
            ))}
          </div>
          <p class="compliance-links">
            <a href="/legal/privacy">Privacy Policy</a> · <a href="/legal/terms">Terms of Service</a> · <a href="/legal/cookies">Cookie Policy</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Enterprise CTA -->
    <section class="fleet-cta below-fold">
      <div class="container">
        <div class="fleet-cta-inner glass reveal">
          <h2>Get a personalised demo</h2>
          <p class="text-muted">We'll walk you through the dispatcher console with your own routes, show you the exception alert flow, and answer every question your operations team has.</p>
          <a href="/contact" class="btn btn-primary">Book your demo</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding-block: 120px 64px;
    text-align: center;
    overflow: hidden;
  }
  .page-hero .container { position: relative; z-index: 2; }
  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    z-index: 0;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to right, rgba(10,12,16,0.97) 0%, rgba(10,12,16,0.78) 30%, rgba(10,12,16,0.38) 52%, transparent 72%);
  }
  .hero-chip { margin-bottom: 16px; display: inline-flex; }
  .page-hero-sub {
    color: var(--ink-muted);
    font-size: 1.125rem;
    margin-top: 12px;
    max-width: 540px;
    margin-inline: auto;
    margin-bottom: 24px;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

  .dp-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 768px) { .dp-inner { grid-template-columns: 1fr 1fr; } }

  .dp-text h2 { margin-bottom: 12px; }
  .dp-list {
    list-style: none;
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .dp-list li { color: var(--ink-muted); font-size: 0.9375rem; padding-left: 20px; position: relative; }
  .dp-list li::before { content: '→'; position: absolute; left: 0; color: var(--brand-bright); }

  .dp-panel {
    border-radius: var(--r-card);
    padding: 0;
    overflow: hidden;
  }
  .dp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--glass-brd);
    background: var(--surface-2);
  }
  .dp-title { font-weight: 600; font-size: 0.9375rem; }
  .dp-drivers { display: flex; flex-direction: column; }
  .dp-driver-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.9rem;
  }
  .dp-driver-row:last-child { border-bottom: none; }
  .dp-driver-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dp-driver-dot.chip-green { background: var(--green); }
  .dp-driver-dot.chip-amber { background: var(--amber); }
  .dp-driver-name { flex: 1; color: var(--ink); font-weight: 500; }
  .dp-driver-stops { font-size: 0.8125rem; }
  .dp-driver-eta { font-size: 0.8125rem; color: var(--brand-bright); }

  /* Compliance strip */
  .compliance-strip { padding-block: var(--section-py); }
  .compliance-inner {
    border-radius: var(--r-panel);
    padding: 48px var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
    text-align: center;
  }
  .compliance-heading { margin: 0; }
  .compliance-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    width: 100%;
  }
  @media (min-width: 640px)  { .compliance-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .compliance-grid { grid-template-columns: repeat(4, 1fr); } }

  .compliance-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px;
    border-radius: var(--r-card);
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-brd);
    text-align: left;
  }
  .compliance-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-md);
    background: rgba(0, 194, 168, 0.08);
    margin-bottom: 4px;
  }
  .compliance-title { font-size: 0.9375rem; font-weight: 600; color: var(--ink); margin: 0; }
  .compliance-body { font-size: 0.875rem; line-height: 1.55; margin: 0; }
  .compliance-links { font-size: 0.875rem; }
  .compliance-links a { color: var(--ink-muted); text-decoration: none; }
  @media (hover: hover) { .compliance-links a:hover { color: var(--brand-bright); } }

  .fleet-cta { padding-block: var(--section-py); }
  .fleet-cta-inner {
    border-radius: var(--r-panel);
    padding: 48px 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .fleet-cta-inner p { max-width: 480px; }
</style>
