---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About — MJ Maps"
  description="MJ Maps Systems — UK-founded navigation technology for professional delivery drivers and fleet operations teams."
>
  <Nav activePage="/about" />
  <main id="main-content">
    <div class="page-hero">
      <div class="container">
        <h1 class="reveal">Built by people who've done the round</h1>
        <p class="page-hero-sub reveal">MJ Maps Systems was founded to solve the routing problems that delivery drivers face every day — problems that consumer maps have never been designed to handle.</p>
      </div>
    </div>

    <section class="about-body below-fold">
      <div class="container about-inner">
        <div class="about-block reveal">
          <h2>The problem we're solving</h2>
          <p>UK delivery drivers face routing challenges that Google Maps and Waze were never built to handle. Postcode centroids that are 50 metres from the gate. Low bridges that appear without warning at the end of a narrow lane. Dead-ends that can't be reversed out of with a laden lorry. Unpaved farm tracks that destroy van suspensions.</p>
          <p>Experienced drivers carry this knowledge in their heads. But there's no way to share it, no way to warn a new driver on their first day, and no consistent way to capture it when a driver leaves.</p>
        </div>

        <div class="about-block reveal">
          <h2>What we built</h2>
          <p>MJ Maps is a navigation platform built specifically for professional delivery — not adapted from a consumer product. Every feature addresses a real delivery scenario:</p>
          <ul class="about-list">
            <li><strong>Turn-score chips</strong> tell the driver what green, amber, or red means for the turn ahead before they reach it.</li>
            <li><strong>Vehicle profiles</strong> filter the entire route for weight, height, and width limits — not just the destination.</li>
            <li><strong>what3words pin delivery</strong> routes to the exact gate or yard entrance, not the postcode centroid.</li>
            <li><strong>Offline mode</strong> caches the full road network for the shift region so signal loss never stops navigation.</li>
            <li><strong>The Dispatcher console</strong> gives operations teams live visibility without requiring drivers to change how they work.</li>
          </ul>
        </div>

        <div class="about-block reveal">
          <h2>Our principles</h2>
          <ul class="about-list">
            <li><strong>Honesty first.</strong> We only advertise features that are shipped and working. If something is in development, we say "coming soon."</li>
            <li><strong>Privacy by design.</strong> Location data is used for navigation and fleet reporting only. We don't sell it, share it, or use it for advertising.</li>
            <li><strong>No lock-in.</strong> Cancel any month. Annual plans don't auto-renew. Your data is exportable.</li>
          </ul>
        </div>

        <div class="about-contact reveal">
          <h2>Get in touch</h2>
          <p class="text-muted">For product questions, fleet demos, or press enquiries:</p>
          <div class="about-ctas">
            <a href="/contact" class="btn btn-primary">Book a fleet demo</a>
            <a href="mailto:hello@mjmaps.app" class="btn btn-secondary">hello@mjmaps.app</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust signals -->
    <section class="trust-section below-fold" aria-label="Trust and compliance">
      <div class="container">
        <div class="trust-grid">
          {[
            { label: 'UK-founded', detail: 'Registered in England and Wales. Built for UK roads, UK regulations, and UK drivers.' },
            { label: 'UK GDPR compliant', detail: 'Registered UK data controller. Location data never sold, never used for advertising.' },
            { label: 'No auto-renew', detail: 'Annual plans require manual renewal. We email you in advance. No surprise charges.' },
            { label: 'VAT inclusive', detail: 'All advertised prices include VAT. No hidden charges at checkout.' },
            { label: 'Honest roadmap', detail: 'We only list features that are live and working. Anything in development is clearly marked "coming soon."' },
            { label: 'Data portability', detail: 'Export your routes, stops, and POD records at any time. Your data leaves when you do.' },
          ].map(t => (
            <div class="trust-card glass reveal">
              <span class="trust-checkmark" aria-hidden="true">✓</span>
              <div class="trust-text">
                <strong class="trust-label">{t.label}</strong>
                <p class="trust-detail text-muted">{t.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding-block: 120px 64px;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0,194,168,0.06) 0%, transparent 60%), var(--void);
    text-align: center;
  }
  .page-hero-sub {
    color: var(--ink-muted);
    font-size: 1.125rem;
    margin-top: 12px;
    max-width: 560px;
    margin-inline: auto;
  }

  .about-inner {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .about-block h2 { margin-bottom: 16px; }
  .about-block p { color: var(--ink-muted); margin-bottom: 12px; }
  .about-block p:last-child { margin-bottom: 0; }

  .about-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 8px;
  }
  .about-list li {
    color: var(--ink-muted);
    padding-left: 20px;
    position: relative;
  }
  .about-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--brand-bright);
  }
  .about-list strong { color: var(--ink); }

  .about-contact {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .about-ctas { display: flex; flex-wrap: wrap; gap: 12px; }

  /* Trust grid */
  .trust-section { padding-block: var(--section-py); }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px)  { .trust-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .trust-grid { grid-template-columns: repeat(3, 1fr); } }

  .trust-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    border-radius: var(--r-card);
    padding: 20px;
  }
  .trust-checkmark {
    color: var(--green);
    font-size: 1.125rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .trust-text { display: flex; flex-direction: column; gap: 4px; }
  .trust-label { font-size: 0.9375rem; font-weight: 600; color: var(--ink); }
  .trust-detail { font-size: 0.875rem; line-height: 1.55; margin: 0; }
</style>
