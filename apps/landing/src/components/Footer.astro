---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="MJ Maps home">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="#00C2A8" fill-opacity="0.15"/>
            <path d="M8 22 L16 8 L24 22" stroke="url(#fg)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="16" cy="8" r="2.5" fill="#2EE6CE"/>
            <circle cx="8" cy="22" r="2" fill="#3B82F6"/>
            <circle cx="24" cy="22" r="2" fill="#3B82F6"/>
            <defs>
              <linearGradient id="fg" x1="8" y1="22" x2="24" y2="8" gradientUnits="userSpaceOnUse">
                <stop stop-color="#3B82F6"/>
                <stop offset="1" stop-color="#2EE6CE"/>
              </linearGradient>
            </defs>
          </svg>
          <span class="footer-wordmark">MJ Maps</span>
        </a>
        <p class="footer-tagline">Routing that knows your van — and the turn at the end of the lane.</p>
        <!-- App store badges (TODO: add real links when live) -->
        <div class="store-badges">
          <a href="#" aria-label="Download on the App Store" class="badge-link">
            <svg width="120" height="40" viewBox="0 0 120 40" fill="none" aria-hidden="true">
              <rect width="120" height="40" rx="8" fill="#1A2533" stroke="rgba(255,255,255,0.1)"/>
              <text x="12" y="14" fill="#8AA0B2" font-size="7" font-family="Inter,sans-serif">Download on the</text>
              <text x="12" y="28" fill="#EAF2FA" font-size="13" font-family="Space Grotesk,sans-serif" font-weight="600">App Store</text>
            </svg>
          </a>
          <a href="#" aria-label="Get it on Google Play" class="badge-link">
            <svg width="120" height="40" viewBox="0 0 120 40" fill="none" aria-hidden="true">
              <rect width="120" height="40" rx="8" fill="#1A2533" stroke="rgba(255,255,255,0.1)"/>
              <text x="12" y="14" fill="#8AA0B2" font-size="7" font-family="Inter,sans-serif">Get it on</text>
              <text x="12" y="28" fill="#EAF2FA" font-size="13" font-family="Space Grotesk,sans-serif" font-weight="600">Google Play</text>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div class="footer-col">
        <h4 class="footer-heading">Product</h4>
        <ul class="footer-links">
          <li><a href="/features">All features</a></li>
          <li><a href="/pricing">Pricing</a></li>
          <li><a href="/drivers">For Drivers</a></li>
          <li><a href="/fleet">For Fleets</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div class="footer-col">
        <h4 class="footer-heading">Support</h4>
        <ul class="footer-links">
          <li><a href="/contact">Book a demo</a></li>
          <li><a href="mailto:hello@mjmaps.app">hello@mjmaps.app</a></li>
          <li><a href="/about">About us</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-col">
        <h4 class="footer-heading">Legal</h4>
        <ul class="footer-links">
          <li><a href="/legal/privacy">Privacy Policy</a></li>
          <li><a href="/legal/terms">Terms of Service</a></li>
          <li><a href="/legal/cookies">Cookie Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} MJ Maps Systems Ltd · UK-founded · VAT-inclusive pricing · No auto-renew</p>
      <p class="footer-contact">
        <a href="mailto:hello@mjmaps.app">hello@mjmaps.app</a> · UK support, responds within 1 business day
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--void-2);
    border-top: 1px solid var(--glass-brd);
    padding-block: 64px 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 48px;
    }
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 16px;
  }

  .footer-wordmark {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--ink);
  }

  .footer-tagline {
    color: var(--ink-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 280px;
    margin-bottom: 24px;
  }

  .store-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .badge-link {
    opacity: 0.7;
    transition: opacity var(--dur-micro) ease-out;
    text-decoration: none;
  }

  @media (hover: hover) {
    .badge-link:hover { opacity: 1; }
  }

  .footer-heading {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: var(--ink-muted);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color var(--dur-micro) ease-out;
  }

  @media (hover: hover) {
    .footer-links a:hover { color: var(--ink); }
  }

  .footer-bottom {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--glass-brd);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy,
  .footer-contact {
    color: var(--ink-faint);
    font-size: 0.875rem;
  }

  .footer-contact a {
    color: var(--ink-muted);
    text-decoration: none;
  }

  @media (hover: hover) {
    .footer-contact a:hover { color: var(--brand-bright); }
  }
</style>
