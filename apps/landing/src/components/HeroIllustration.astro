---
/**
 * HeroIllustration.astro
 *
 * Dark cinematic SVG illustration for the homepage hero.
 * Shows a UK delivery van on a night road with a live navigation HUD overlay.
 * Turn-score chip (GREEN) visible, route polyline on road.
 *
 * All SVG — no external image dependency. Fully responsive.
 * ViewBox: 0 0 800 500 (landscape, fits hero layout).
 */
---

<svg
  viewBox="0 0 800 500"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Delivery van navigating a UK road at night with MJ Maps HUD"
  class="hero-illustration"
  role="img"
>
  <defs>
    <!-- Road gradient -->
    <linearGradient id="roadGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1A1F26"/>
      <stop offset="100%" stop-color="#0D1117"/>
    </linearGradient>

    <!-- Sky gradient -->
    <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#07090D"/>
      <stop offset="100%" stop-color="#0A0C10"/>
    </linearGradient>

    <!-- Glow effect for headlights -->
    <radialGradient id="headlightGlow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#FFE4A0" stop-opacity="0.6"/>
      <stop offset="100%" stop-color="#FFE4A0" stop-opacity="0"/>
    </radialGradient>

    <!-- Teal HUD glow -->
    <filter id="hudGlow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- Route line glow -->
    <filter id="routeGlow" x="-50%" y="-200%" width="200%" height="500%">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- Van body gradient -->
    <linearGradient id="vanBody" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#2A3040"/>
      <stop offset="100%" stop-color="#1A2030"/>
    </linearGradient>
  </defs>

  <!-- Sky / background -->
  <rect width="800" height="500" fill="url(#skyGrad)"/>

  <!-- Stars (subtle, sparse) -->
  <g fill="#FFFFFF" opacity="0.4">
    <circle cx="80"  cy="30"  r="1"/>
    <circle cx="160" cy="15"  r="0.8"/>
    <circle cx="240" cy="45"  r="1.2"/>
    <circle cx="350" cy="20"  r="0.7"/>
    <circle cx="460" cy="35"  r="1"/>
    <circle cx="580" cy="12"  r="0.9"/>
    <circle cx="680" cy="40"  r="1.1"/>
    <circle cx="750" cy="18"  r="0.8"/>
    <circle cx="120" cy="60"  r="0.6"/>
    <circle cx="520" cy="55"  r="0.7"/>
  </g>

  <!-- Distant road vanishing point (horizon) -->
  <g opacity="0.3">
    <line x1="400" y1="200" x2="0"   y2="500" stroke="#1A2030" stroke-width="1"/>
    <line x1="400" y1="200" x2="800" y2="500" stroke="#1A2030" stroke-width="1"/>
    <line x1="400" y1="200" x2="200" y2="500" stroke="#1A2030" stroke-width="0.5"/>
    <line x1="400" y1="200" x2="600" y2="500" stroke="#1A2030" stroke-width="0.5"/>
  </g>

  <!-- Main road surface -->
  <polygon points="260,500 540,500 480,200 320,200" fill="url(#roadGrad)"/>

  <!-- Road edge lines -->
  <line x1="280" y1="500" x2="360" y2="200" stroke="#334155" stroke-width="2"/>
  <line x1="520" y1="500" x2="440" y2="200" stroke="#334155" stroke-width="2"/>

  <!-- Centre dashed line -->
  <g stroke="#334155" stroke-width="1.5" stroke-dasharray="20,16">
    <line x1="400" y1="500" x2="390" y2="210"/>
  </g>

  <!-- Animated route polyline (teal, glows) -->
  <g filter="url(#routeGlow)">
    <path
      d="M 400 500 C 390 440 385 380 375 330 C 365 280 355 240 360 210 C 365 185 380 170 400 160 C 420 150 445 140 470 125"
      stroke="#00C2A8"
      stroke-width="3.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
  </g>

  <!-- Stop marker dots along route -->
  <circle cx="375" cy="330" r="5" fill="#3B82F6"/>
  <circle cx="360" cy="210" r="5" fill="#3B82F6"/>
  <circle cx="470" cy="125" r="7" fill="#10B981" filter="url(#hudGlow)"/>
  <circle cx="470" cy="125" r="13" fill="#10B981" fill-opacity="0.2"/>

  <!-- Headlight glow pools on road -->
  <ellipse cx="400" cy="500" rx="80" ry="40" fill="url(#headlightGlow)"/>

  <!-- ── DELIVERY VAN (simplified, bold silhouette) ── -->
  <g transform="translate(300, 280)">
    <!-- Van shadow -->
    <ellipse cx="100" cy="200" rx="110" ry="15" fill="#000000" fill-opacity="0.4"/>

    <!-- Wheels -->
    <circle cx="45"  cy="195" r="28" fill="#111820" stroke="#334155" stroke-width="2"/>
    <circle cx="45"  cy="195" r="12" fill="#1A2030" stroke="#00C2A8" stroke-width="1" stroke-opacity="0.3"/>
    <circle cx="155" cy="195" r="28" fill="#111820" stroke="#334155" stroke-width="2"/>
    <circle cx="155" cy="195" r="12" fill="#1A2030" stroke="#00C2A8" stroke-width="1" stroke-opacity="0.3"/>

    <!-- Van body (side view, simplified) -->
    <!-- Rear section -->
    <rect x="10" y="60" width="180" height="130" rx="8" fill="url(#vanBody)" stroke="#334155" stroke-width="1.5"/>
    <!-- Cab section -->
    <path d="M 190 80 Q 220 80 225 120 L 225 190 L 190 190 Z" fill="url(#vanBody)" stroke="#334155" stroke-width="1.5"/>
    <!-- Roof line -->
    <rect x="10" y="55" width="215" height="12" rx="4" fill="#1F2835" stroke="#334155" stroke-width="1"/>

    <!-- Cargo door lines -->
    <line x1="105" y1="70" x2="105" y2="180" stroke="#334155" stroke-width="1" stroke-opacity="0.6"/>
    <line x1="10"  y1="125" x2="190" y2="125" stroke="#334155" stroke-width="1" stroke-opacity="0.4"/>

    <!-- Side windows -->
    <rect x="195" y="88" width="24" height="30" rx="4" fill="#0A0C10" stroke="#334155" stroke-width="1"/>
    <rect x="195" y="122" width="24" height="22" rx="3" fill="#0A0C10" stroke="#334155" stroke-width="1"/>

    <!-- Cargo area tint (very subtle teal reflection) -->
    <rect x="12" y="62" width="90" height="126" rx="6" fill="#00C2A8" fill-opacity="0.03"/>

    <!-- Headlights (front of cab) -->
    <rect x="222" y="155" width="6" height="12" rx="2" fill="#FFE4A0" filter="url(#hudGlow)"/>
    <rect x="222" y="140" width="6" height="10" rx="2" fill="#FFE4A0" opacity="0.5"/>

    <!-- Registration plate -->
    <rect x="224" y="168" width="8" height="10" rx="1" fill="#1A2030" stroke="#334155" stroke-width="0.5"/>
    <text x="228" y="176" font-family="monospace" font-size="4" fill="#94A3B8" text-anchor="middle">DU24 XYZ</text>

    <!-- Door handle -->
    <rect x="155" y="140" width="14" height="5" rx="2.5" fill="#334155"/>

    <!-- MJ Maps logo on cargo door (small) -->
    <g transform="translate(50, 90)">
      <rect width="28" height="28" rx="5" fill="#00C2A8" fill-opacity="0.15"/>
      <path d="M 6 20 L 14 6 L 22 20" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <circle cx="14" cy="6" r="2" fill="#00E8D4"/>
      <circle cx="6"  cy="20" r="1.5" fill="#3B82F6"/>
      <circle cx="22" cy="20" r="1.5" fill="#3B82F6"/>
    </g>
  </g>

  <!-- ── NAVIGATION HUD OVERLAY (top-right quadrant) ── -->
  <g transform="translate(480, 20)">
    <!-- HUD panel background -->
    <rect x="0" y="0" width="300" height="200" rx="14" fill="#0A0C10" stroke="#334155" stroke-width="1.5" opacity="0.95"/>

    <!-- HUD status bar -->
    <rect x="0" y="0" width="300" height="36" rx="14" fill="#0D1117"/>
    <rect x="0" y="20" width="300" height="16" fill="#0D1117"/>
    <text x="16" y="24" font-family="system-ui" font-size="12" fill="#94A3B8">9:41</text>
    <!-- Signal bars -->
    <g fill="#64748B">
      <rect x="230" y="18" width="4" height="4" rx="1"/>
      <rect x="237" y="14" width="4" height="8" rx="1"/>
      <rect x="244" y="10" width="4" height="12" rx="1"/>
      <rect x="251" y="6"  width="4" height="16" rx="1" fill="#10B981"/>
      <rect x="258" y="6"  width="4" height="16" rx="1" fill="#10B981"/>
    </g>
    <text x="273" y="24" font-family="system-ui" font-size="10" fill="#64748B">GPS</text>

    <!-- Map area -->
    <rect x="0" y="36" width="300" height="100" fill="#0D1117"/>

    <!-- Mini route on HUD map -->
    <g stroke="#1A2030" stroke-width="1">
      <line x1="0" y1="86" x2="300" y2="86"/>
      <line x1="150" y1="36" x2="150" y2="136"/>
    </g>
    <!-- Route on mini map -->
    <path d="M 20 120 L 80 95 L 130 80 L 190 65 L 250 50"
          stroke="#00C2A8" stroke-width="2.5" stroke-linecap="round" fill="none"/>
    <!-- Vehicle dot on route -->
    <circle cx="20" cy="120" r="5" fill="#00C2A8"/>
    <!-- Stop dot -->
    <circle cx="190" cy="65" r="4" fill="#3B82F6"/>
    <!-- Destination -->
    <circle cx="250" cy="50" r="6" fill="#10B981"/>
    <circle cx="250" cy="50" r="11" fill="#10B981" fill-opacity="0.2"/>

    <!-- Turn instruction card -->
    <rect x="0" y="136" width="300" height="64" fill="#12151B" stroke="#334155" stroke-width="1"/>
    <!-- Turn icon circle -->
    <rect x="12" y="148" width="40" height="40" rx="10" fill="rgba(16,185,129,0.15)"/>
    <path d="M 26 163 L 34 155 L 42 163 M 34 155 L 34 168"
          stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <!-- Distance -->
    <text x="64" y="164" font-family="system-ui" font-size="16" font-weight="700" fill="#F1F5F9">0.3 mi</text>
    <!-- Road name -->
    <text x="64" y="182" font-family="system-ui" font-size="11" fill="#94A3B8">Turn right onto</text>
    <text x="64" y="195" font-family="system-ui" font-size="13" font-weight="600" fill="#F1F5F9">Long Lane, B4132</text>

    <!-- GREEN score chip -->
    <rect x="215" y="148" width="70" height="26" rx="13" fill="rgba(16,185,129,0.15)" stroke="#10B981" stroke-width="1"/>
    <text x="250" y="165" font-family="system-ui" font-size="11" font-weight="700" fill="#10B981" text-anchor="middle">GREEN</text>

    <!-- Stop progress bar -->
    <rect x="12" y="136" width="276" height="3" rx="1.5" fill="#1A2030"/>
    <rect x="12" y="136" width="100" height="3" rx="1.5" fill="#00C2A8"/>
    <text x="14" y="133" font-family="system-ui" font-size="9" fill="#64748B">12 / 32 stops</text>
  </g>

  <!-- Teal coordinate label (mono, bottom-left) -->
  <text x="16" y="488" font-family="'IBM Plex Mono', monospace" font-size="11" fill="#64748B" fill-opacity="0.6">
    51.5074° N, 0.1278° W
  </text>

  <!-- Turn-score chip overlay (bottom of illustration) -->
  <g transform="translate(600, 440)">
    <rect width="180" height="40" rx="20" fill="rgba(16,185,129,0.12)" stroke="#10B981" stroke-width="1.5" filter="url(#hudGlow)"/>
    <text x="90" y="25" font-family="system-ui" font-size="12" font-weight="700" fill="#10B981" text-anchor="middle" letter-spacing="0.08em">GREEN — CLEAR JUNCTION</text>
  </g>

  <!-- Route distance label -->
  <g transform="translate(16, 440)">
    <text font-family="'IBM Plex Mono', monospace" font-size="10" fill="#64748B" fill-opacity="0.7">
      <tspan x="0" dy="0">MJ Maps v4.2.1</tspan>
      <tspan x="0" dy="14">Route: 34.7 km · 28 stops</tspan>
    </text>
  </g>
</svg>

<style>
  .hero-illustration {
    width: 100%;
    height: auto;
    max-height: 480px;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-illustration {
      /* Static — no animation needed */
    }
  }
</style>
