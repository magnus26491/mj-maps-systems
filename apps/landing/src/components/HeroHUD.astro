---
/**
 * HeroHUD — live turn-score HUD card shown on the hero right column.
 *
 * Props:
 *   photo:  key from photos.ts (used as background on the card)
 *   score:  'green' | 'amber' | 'red'
 */
import { photos } from '../assets/photos';

interface Props {
  photo?: string;
  score?: 'green' | 'amber' | 'red';
}

const { score = 'green' } = Astro.props;

const scoreLabel: Record<string, string> = {
  green: 'GREEN',
  amber: 'AMBER',
  red:   'RED',
};

const scoreColor: Record<string, string> = {
  green: '#10B981',
  amber: '#F59E0B',
  red:   '#EF4444',
};

const bgPhoto = photos.heroHudNight;
---

<div class="hud-shell">
  <!-- Real road photo as card background -->
  <div
    class="hud-photo-bg"
    style={`background-image: url('${bgPhoto}')`}
    aria-hidden="true"
  ></div>
  <!-- Dark overlay so HUD text stays readable -->
  <div class="hud-overlay" aria-hidden="true"></div>

  <!-- Top chip: next manoeuvre -->
  <div class="hud-row hud-top">
    <div class="hud-arrow-chip">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="hud-manoeuvre">
      <span class="hud-dist">0.3 mi</span>
      <span class="hud-road">Long Lane, B4132</span>
    </div>
    <div class="hud-score-chip" style={`color: ${scoreColor[score]}`}>
      {scoreLabel[score]}
    </div>
  </div>

  <!-- Divider -->
  <div class="hud-divider" aria-hidden="true"></div>

  <!-- Bottom row: ETA + stops + total distance -->
  <div class="hud-row hud-bottom">
    <div class="hud-stat">
      <span class="hud-stat-label">ETA</span>
      <span class="hud-stat-val hud-stat-bold">14:32</span>
    </div>
    <div class="hud-dot" aria-hidden="true"></div>
    <div class="hud-stat">
      <span class="hud-stat-val hud-stat-bold">4</span>
      <span class="hud-stat-label">stops left</span>
    </div>
    <div class="hud-dot" aria-hidden="true"></div>
    <div class="hud-stat">
      <span class="hud-stat-val hud-stat-bold">12.4 mi</span>
    </div>
  </div>
</div>

<style>
  .hud-shell {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.10);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6), 0 4px 16px rgba(0, 0, 0, 0.4);
    background: #0f1117;
    padding: 20px 24px;
    min-width: 280px;
    max-width: 420px;
  }

  .hud-photo-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  .hud-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 12, 20, 0.72);
    z-index: 1;
  }

  .hud-row {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .hud-top {
    margin-bottom: 0;
  }

  .hud-divider {
    position: relative;
    z-index: 2;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin-block: 16px;
  }

  .hud-arrow-chip {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(0, 194, 168, 0.15);
    border: 1px solid rgba(0, 194, 168, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #00C2A8;
    flex-shrink: 0;
  }

  .hud-manoeuvre {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .hud-dist {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 1.125rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1;
  }

  .hud-road {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .hud-score-chip {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .hud-bottom {
    gap: 10px;
  }

  .hud-stat {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .hud-stat-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
  }

  .hud-stat-val {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.85);
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
  }

  .hud-stat-bold {
    font-weight: 700;
    color: #ffffff;
  }

  .hud-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    flex-shrink: 0;
  }
</style>
