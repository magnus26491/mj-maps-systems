---
/**
 * TurnScoreDemo.astro — Inline animated turn-score demonstration
 *
 * SVG road segment with vehicle. Three states (cycling or scroll-triggered):
 * GREEN → AMBER → RED with animated score bar and message.
 * Respects prefers-reduced-motion.
 *
 * Props:
 *   autoCycle: boolean  — cycle through states automatically (default: true)
 *   initialState: 'green' | 'amber' | 'red'  (default: 'green')
 *   class: additional CSS classes
 */

interface Props {
  autoCycle?: boolean;
  initialState?: 'green' | 'amber' | 'red';
  class?: string;
}

const {
  autoCycle = true,
  initialState = 'green',
  class: className = '',
} = Astro.props;

const states = ['green', 'amber', 'red'] as const;
const initialIndex = states.indexOf(initialState);

const messages: Record<string, { heading: string; sub: string; badge: string }> = {
  green: {
    heading: 'GREEN — clear junction',
    sub: 'Vehicle fits comfortably. Road width 7.2m.',
    badge: 'GREEN',
  },
  amber: {
    heading: 'AMBER — take care',
    sub: 'Tight turn for this vehicle. Reduce speed to <15 mph.',
    badge: 'AMBER',
  },
  red: {
    heading: 'RED — do not attempt',
    sub: 'Bridge height 3.8m. Vehicle clearance 4.2m. Rerouting.',
    badge: 'RED',
  },
};
---

<div
  class:list={['turn-demo', `turn-state-${initialState}`, className]}
  data-auto-cycle={autoCycle ? 'true' : 'false'}
  data-initial-index={initialIndex}
  aria-live="polite"
  aria-label="Turn score demonstration"
>
  <!-- SVG road scene -->
  <div class="turn-scene" aria-hidden="true">
    <!-- Real photo background: night driving scene with HUD -->
    <picture>
      <source srcset="/img/photos/turn-score-night.webp" type="image/webp" />
      <img
        src="/img/photos/turn-score-night.png"
        alt="Night driving scene — MJ Maps navigation HUD with GREEN turn score"
        class="turn-map-bg"
        width="320"
        height="180"
        loading="lazy"
      />
    </picture>
    <!-- Turn score SVG overlay -->
    <svg
      class="turn-svg"
      viewBox="0 0 320 180"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <!-- Road surface -->
        <linearGradient id="road-surface" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#1A1F26"/>
          <stop offset="100%" stop-color="#12151B"/>
        </linearGradient>

        <!-- Glow for score colour -->
        <filter id="ts-glow" x="-30%" y="-30%" width="160%" height="160%">
          <feGaussianBlur stdDeviation="4" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>

        <!-- Drop shadow for vehicle -->
        <filter id="van-shadow" x="-20%" y="-20%" width="140%" height="160%">
          <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="rgba(0,0,0,0.5)"/>
        </filter>
      </defs>

      <!-- Background ground -->
      <rect width="320" height="180" fill="#0A0C10"/>

      <!-- Road: approaching straight then turning right -->
      <!-- Incoming road (from left) -->
      <path
        d="M -10 100 L 120 100"
        stroke="url(#road-surface)"
        stroke-width="28"
        stroke-linecap="butt"
      />

      <!-- Junction box -->
      <rect x="100" y="76" width="80" height="80" rx="4" fill="#1A1F26"/>

      <!-- Road: going right (exit) -->
      <path
        d="M 120 136 L 220 136 L 260 136"
        stroke="url(#road-surface)"
        stroke-width="28"
        stroke-linecap="butt"
      />

      <!-- Road edges (white dashes) -->
      <g stroke="rgba(255,255,255,0.12)" stroke-width="1.5" stroke-dasharray="8 8">
        <line x1="-10" y1="86" x2="100" y2="86"/>
        <line x1="-10" y1="114" x2="100" y2="114"/>
        <line x1="120" y1="122" x2="260" y2="122"/>
        <line x1="120" y1="150" x2="260" y2="150"/>
      </g>

      <!-- Centre line dashes -->
      <g stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="12 10">
        <line x1="-10" y1="100" x2="100" y2="100"/>
        <line x1="120" y1="136" x2="260" y2="136"/>
      </g>

      <!-- Junction markings -->
      <g stroke="rgba(255,255,255,0.08)" stroke-width="1">
        <!-- Box junction hatching -->
        <line x1="105" y1="80" x2="115" y2="90"/>
        <line x1="115" y1="80" x2="125" y2="90"/>
        <line x1="125" y1="80" x2="135" y2="90"/>
        <line x1="135" y1="80" x2="145" y2="90"/>
        <line x1="145" y1="80" x2="155" y2="90"/>
        <line x1="155" y1="80" x2="165" y2="90"/>
        <line x1="165" y1="80" x2="175" y2="90"/>
      </g>

      <!-- Turn arrow (animated, colour changes with score) -->
      <g class="turn-arrow" filter="url(#ts-glow)">
        <path
          d="M 105 100 L 118 100 L 118 94 L 132 106 L 118 118 L 118 112 L 105 112 Z"
          fill="currentColor"
          class="turn-arrow-path"
        />
      </g>

      <!-- Vehicle (white van, approaching the junction) -->
      <g class="van-group" filter="url(#van-shadow)" transform="translate(20, 78)">
        <!-- Van body -->
        <rect x="0" y="8" width="56" height="28" rx="4" fill="#1E293B" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
        <!-- Cab (front) -->
        <rect x="48" y="4" width="20" height="36" rx="4" fill="#1E293B" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
        <!-- Windscreen -->
        <rect x="52" y="8" width="12" height="14" rx="2" fill="rgba(0,194,168,0.15)" stroke="rgba(0,194,168,0.3)" stroke-width="0.5"/>
        <!-- Side windows -->
        <rect x="8" y="12" width="14" height="10" rx="2" fill="rgba(0,194,168,0.10)"/>
        <rect x="26" y="12" width="14" height="10" rx="2" fill="rgba(0,194,168,0.10)"/>
        <!-- Wheels -->
        <circle cx="16" cy="38" r="6" fill="#0F1318" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
        <circle cx="56" cy="38" r="6" fill="#0F1318" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
        <!-- Wheel hubs -->
        <circle cx="16" cy="38" r="2.5" fill="rgba(255,255,255,0.15)"/>
        <circle cx="56" cy="38" r="2.5" fill="rgba(255,255,255,0.15)"/>
        <!-- Side door line -->
        <line x1="24" y1="8" x2="24" y2="36" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
        <!-- Roof rack hint -->
        <rect x="4" y="5" width="40" height="3" rx="1" fill="rgba(255,255,255,0.06)"/>
      </g>

      <!-- Road sign (junction ahead indicator) -->
      <g transform="translate(60, 20)">
        <rect x="0" y="0" width="36" height="24" rx="3" fill="#1A1F26" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
        <path d="M 12 18 L 18 6 L 24 18 Z" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
      </g>

      <!-- Score indicator pip (top right) -->
      <g class="score-pip" transform="translate(280, 20)">
        <circle cx="0" cy="0" r="18" fill="#12151B" stroke="currentColor" stroke-width="2" class="score-pip-ring"/>
        <circle cx="0" cy="0" r="6" fill="currentColor" class="score-pip-dot"/>
      </g>
    </svg>
  </div>

  <!-- Score display -->
  <div class="turn-info">
    <div class="turn-badge-row">
      <span class="chip chip-green turn-chip" aria-label="Turn score: green">GREEN</span>
      <span class="turn-code mono">51.5074° N, 0.1278° W</span>
    </div>
    <h3 class="turn-heading">GREEN — clear junction</h3>
    <p class="turn-sub">Vehicle fits comfortably. Road width 7.2m.</p>

    <!-- Score bar -->
    <div class="turn-bar-track" role="progressbar" aria-valuenow="92" aria-valuemin="0" aria-valuemax="100" aria-label="Turn score 92 out of 100">
      <div class="turn-bar-fill turn-bar-green" style="width: 92%"></div>
    </div>
    <div class="turn-bar-labels">
      <span class="mono">0</span>
      <span class="mono turn-bar-score">92/100</span>
      <span class="mono">100</span>
    </div>

    <!-- State toggle buttons -->
    <div class="turn-controls" role="group" aria-label="Select turn score to demo">
      <button class="turn-btn turn-btn-green active" data-state="green" aria-pressed="true">
        <span class="turn-btn-dot"></span>GREEN
      </button>
      <button class="turn-btn turn-btn-amber" data-state="amber" aria-pressed="false">
        <span class="turn-btn-dot"></span>AMBER
      </button>
      <button class="turn-btn turn-btn-red" data-state="red" aria-pressed="false">
        <span class="turn-btn-dot"></span>RED
      </button>
    </div>
  </div>
</div>

<style>
  .turn-demo {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background: var(--color-surface-1);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--elevation-1);
  }

  @media (min-width: 640px) {
    .turn-demo {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ─── Scene ───────────────────────────────────────────────────────── */

  .turn-scene {
    background: #0A0C10;
    overflow: hidden;
    position: relative;
  }

  .turn-map-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }

  .turn-svg {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
    z-index: 1;
  }

  .turn-arrow {
    color: var(--green);
    transition: color 400ms ease;
  }

  .turn-demo.turn-state-amber .turn-arrow { color: var(--amber); }
  .turn-demo.turn-state-red   .turn-arrow { color: var(--red); }

  .score-pip {
    color: var(--green);
    transition: color 400ms ease;
  }

  .turn-demo.turn-state-amber .score-pip { color: var(--amber); }
  .turn-demo.turn-state-red   .score-pip { color: var(--red); }

  /* ─── Info panel ──────────────────────────────────────────────────── */

  .turn-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
  }

  .turn-badge-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .turn-chip {
    transition: background 300ms ease, color 300ms ease;
  }

  .turn-code {
    color: var(--ink-faint);
    font-size: 0.75rem;
  }

  .turn-heading {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    transition: color 300ms ease;
  }

  .turn-demo.turn-state-amber .turn-heading { color: var(--amber); }
  .turn-demo.turn-state-red   .turn-heading { color: var(--red); }

  .turn-sub {
    font-size: 0.875rem;
    color: var(--ink-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ─── Score bar ───────────────────────────────────────────────────── */

  .turn-bar-track {
    width: 100%;
    height: 6px;
    background: var(--color-surface-2);
    border-radius: var(--r-pill);
    overflow: hidden;
  }

  .turn-bar-fill {
    height: 100%;
    border-radius: var(--r-pill);
    transition: width 600ms cubic-bezier(0.34, 1.56, 0.64, 1),
                background 400ms ease;
  }

  .turn-bar-green { background: var(--green); }
  .turn-bar-amber { background: var(--amber); }
  .turn-bar-red   { background: var(--red); }

  .turn-bar-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--ink-faint);
    margin-top: 4px;
  }

  .turn-bar-score {
    color: var(--ink-muted);
    font-weight: 600;
  }

  /* ─── Control buttons ─────────────────────────────────────────────── */

  .turn-controls {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .turn-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--r-pill);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border: 1px solid transparent;
    cursor: pointer;
    background: var(--color-surface-2);
    color: var(--ink-muted);
    transition: all var(--dur-micro) ease-out;
    -webkit-tap-highlight-color: transparent;
  }

  .turn-btn-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  .turn-btn-green.active {
    background: var(--green-bg);
    color: var(--green);
    border-color: rgba(16, 185, 129, 0.3);
  }

  .turn-btn-amber.active {
    background: var(--amber-bg);
    color: var(--amber);
    border-color: rgba(245, 158, 11, 0.3);
  }

  .turn-btn-red.active {
    background: var(--red-bg);
    color: var(--red);
    border-color: rgba(239, 68, 68, 0.3);
  }

  @media (hover: hover) {
    .turn-btn:hover {
      background: var(--color-surface-2);
      color: var(--ink);
    }
  }

  .turn-btn:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
  }

  /* ─── Reduced motion ──────────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .turn-arrow,
    .score-pip,
    .turn-chip,
    .turn-bar-fill,
    .turn-btn {
      transition: none;
    }
  }
</style>

<script>
  const scoreData: Record<string, { score: number; heading: string; sub: string; barClass: string }> = {
    green: {
      score: 92,
      heading: 'GREEN — clear junction',
      sub: 'Vehicle fits comfortably. Road width 7.2m.',
      barClass: 'turn-bar-green',
    },
    amber: {
      score: 58,
      heading: 'AMBER — take care',
      sub: 'Tight turn for this vehicle. Reduce speed to <15 mph.',
      barClass: 'turn-bar-amber',
    },
    red: {
      score: 18,
      heading: 'RED — do not attempt',
      sub: 'Bridge height 3.8m. Vehicle clearance 4.2m. Rerouting.',
      barClass: 'turn-bar-red',
    },
  };

  function initTurnDemo(el: HTMLElement) {
    const stateBtns = el.querySelectorAll<HTMLButtonElement>('.turn-btn');
    const chip = el.querySelector<HTMLElement>('.turn-chip')!;
    const heading = el.querySelector<HTMLElement>('.turn-heading')!;
    const sub = el.querySelector<HTMLElement>('.turn-sub')!;
    const barFill = el.querySelector<HTMLElement>('.turn-bar-fill')!;
    const barScore = el.querySelector<HTMLElement>('.turn-bar-score')!;
    const barTrack = el.querySelector<HTMLElement>('.turn-bar-track')!;

    function setState(state: string) {
      const data = scoreData[state];
      if (!data) return;

      // Update container class
      el.classList.remove('turn-state-green', 'turn-state-amber', 'turn-state-red');
      el.classList.add(`turn-state-${state}`);

      // Update chip
      chip.textContent = state.toUpperCase();
      chip.className = `chip chip-${state} turn-chip`;

      // Update heading
      heading.textContent = data.heading;

      // Update sub
      sub.textContent = data.sub;

      // Update bar
      barFill.style.width = `${data.score}%`;
      barFill.className = `turn-bar-fill ${data.barClass}`;
      barScore.textContent = `${data.score}/100`;
      barTrack.setAttribute('aria-valuenow', String(data.score));

      // Update buttons
      stateBtns.forEach(btn => {
        const isActive = btn.dataset.state === state;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    // Button click handlers
    stateBtns.forEach(btn => {
      btn.addEventListener('click', () => setState(btn.dataset.state ?? 'green'));
    });

    // Auto-cycle
    const autoCycle = el.dataset.autoCycle === 'true';
    if (autoCycle) {
      let idx = parseInt(el.dataset.initialIndex ?? '0');
      setInterval(() => {
        idx = (idx + 1) % 3;
        const states = ['green', 'amber', 'red'];
        setState(states[idx]);
      }, 3200);
    }
  }

  document.querySelectorAll<HTMLElement>('.turn-demo').forEach(initTurnDemo);
</script>