---
import { PLAN_META, PLAN_FEATURES, FEATURE_META, PRICES, YEARLY_SAVINGS, type Currency, type Period, type PlanId } from '@plans';

interface Props {
  showToggle?: boolean;
}
const { showToggle = true } = Astro.props;

// Plans to show in order
const planIds: PlanId[] = ['navigation', 'custom'];
---

<section class="pricing-section below-fold" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    <div class="section-label reveal">Pricing</div>
    <h2 id="pricing-heading" class="reveal">Simple, honest pricing</h2>
    <p class="section-sub reveal">No hidden fees. No auto-renew surprises. Cancel any month — your account stays active until the period ends.</p>

    {showToggle && (
      <div class="pricing-toggle reveal" role="group" aria-label="Billing period">
        <button id="toggle-monthly" class="toggle-btn active" aria-pressed="true">Monthly</button>
        <button id="toggle-yearly"  class="toggle-btn" aria-pressed="false">
          Yearly
          <span class="toggle-save chip chip-green">Save ~2 months</span>
        </button>
      </div>
    )}

    <div class="currency-select reveal">
      <label for="currency-picker" class="sr-only">Currency</label>
      <select id="currency-picker" class="currency-picker" aria-label="Select currency">
        <option value="GBP">£ GBP</option>
        <option value="EUR">€ EUR</option>
        <option value="USD">$ USD</option>
      </select>
    </div>

    <div class="pricing-grid">
      {planIds.map((planId, idx) => {
        const meta = PLAN_META[planId];
        const prices = PRICES[planId];
        const features = PLAN_FEATURES[planId];
        return (
          <div class={`pricing-card card reveal${meta.highlight ? ' pricing-card-highlight' : ''}`} data-delay={String(idx * 100)}>
            {meta.badge && <div class="pricing-badge chip chip-brand">{meta.badge}</div>}

            <div class="pricing-plan-name">{meta.displayName}</div>
            <p class="pricing-tagline text-muted">{meta.tagline}</p>

            <div class="pricing-price" id={`price-${planId}`} data-plan={planId}>
              {prices.GBP.monthly === null ? (
                <span class="price-custom">Custom</span>
              ) : (
                <>
                  <span class="price-currency">£</span>
                  <span class="price-amount mono" data-gbp-monthly={prices.GBP.monthly} data-gbp-yearly={prices.GBP.yearly}
                    data-eur-monthly={prices.EUR.monthly} data-eur-yearly={prices.EUR.yearly}
                    data-usd-monthly={prices.USD.monthly} data-usd-yearly={prices.USD.yearly}>
                    {prices.GBP.monthly?.toFixed(2)}
                  </span>
                  <span class="price-period">/mo</span>
                </>
              )}
            </div>

            {planId === 'navigation' && (
              <p class="price-save text-muted" id="save-navigation">
                Yearly: <strong class="save-amount">£97.00/yr</strong> — save {YEARLY_SAVINGS.navigation.GBP}
              </p>
            )}

            <a href={meta.ctaHref} class={`btn btn-primary pricing-cta${meta.highlight ? '' : ' btn-secondary'}`}>
              {meta.cta}
            </a>

            <ul class="pricing-features">
              {(features as readonly string[]).map(key => (
                <li class="pricing-feature-item">
                  <span class="feature-check" aria-hidden="true">✓</span>
                  <span>{FEATURE_META[key as keyof typeof FEATURE_META]?.label ?? key}</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>

    <p class="pricing-footnote text-muted reveal">
      All plans include VAT where applicable. Pricing in GBP by default; EUR and USD shown for international customers.
      <strong>No auto-renew on yearly plans</strong> — we'll remind you 30 days before expiry and you choose whether to renew.
    </p>
  </div>
</section>

<style>
  .pricing-section h2 {
    text-align: center;
    margin-bottom: 12px;
  }

  .pricing-toggle {
    display: flex;
    gap: 4px;
    background: var(--surface);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-pill);
    padding: 4px;
    width: fit-content;
    margin-inline: auto;
    margin-bottom: 20px;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    border-radius: var(--r-pill);
    padding: 8px 20px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background var(--dur-micro) ease-out,
                color var(--dur-micro) ease-out;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .toggle-btn.active {
    background: var(--brand);
    color: #000;
    font-weight: 600;
  }

  @media (hover: hover) {
    .toggle-btn:not(.active):hover {
      color: var(--ink);
      background: var(--surface-2);
    }
  }

  .toggle-save { font-size: 0.7rem; }

  .currency-select {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  .currency-picker {
    background: var(--surface);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-btn);
    color: var(--ink-muted);
    font-size: 0.875rem;
    padding: 6px 12px;
    cursor: pointer;
    font-family: inherit;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }

  @media (min-width: 640px) {
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pricing-card-highlight {
    border-color: var(--brand);
    box-shadow: var(--glow), var(--sh-md);
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
  }

  .pricing-plan-name {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    margin-top: 8px;
  }

  .pricing-tagline { font-size: 0.9375rem; }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .price-currency {
    font-size: 1.5rem;
    color: var(--ink-muted);
    font-weight: 600;
    margin-right: 2px;
  }

  .price-amount {
    font-family: 'Geist Mono', monospace;
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
  }

  .price-period {
    font-size: 1rem;
    color: var(--ink-muted);
    margin-left: 4px;
  }

  .price-custom {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--ink);
  }

  .price-save { font-size: 0.875rem; }

  .save-amount { color: var(--green); }

  .pricing-cta { width: 100%; }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .pricing-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.9375rem;
    color: var(--ink-muted);
  }

  .feature-check {
    color: var(--green);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pricing-footnote {
    font-size: 0.875rem;
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }
</style>

<script>
  // ─── Pricing toggle (monthly / yearly) ────────────────────────────
  const btnMonthly = document.getElementById('toggle-monthly');
  const btnYearly  = document.getElementById('toggle-yearly');
  const picker     = document.getElementById('currency-picker') as HTMLSelectElement | null;

  if (!btnMonthly || !btnYearly) { /* static-only fallback */ }

  let period: 'monthly' | 'yearly' = 'monthly';
  let currency: 'GBP' | 'EUR' | 'USD' = 'GBP';

  const currencySymbols: Record<string, string> = { GBP: '£', EUR: '€', USD: '$' };
  const currencyYearlySave: Record<string, string> = { GBP: '£22.64', EUR: '€27.64', USD: '$31.64' };

  function updatePrices() {
    const amounts = document.querySelectorAll<HTMLElement>('.price-amount');
    const currencies = document.querySelectorAll<HTMLElement>('.price-currency');
    const saveEl = document.getElementById('save-navigation');

    amounts.forEach(el => {
      const key = `${currency.toLowerCase()}-${period}` as const;
      const val = el.dataset[key.replace('-', '') as keyof typeof el.dataset];
      if (val !== undefined) el.textContent = parseFloat(val).toFixed(2);
    });

    currencies.forEach(el => {
      el.textContent = currencySymbols[currency] ?? '£';
    });

    if (saveEl) {
      const symbol = currencySymbols[currency];
      const yearlyVal = { GBP: '97.00', EUR: '116.00', USD: '130.00' }[currency];
      const save = currencyYearlySave[currency];
      saveEl.innerHTML = `Yearly: <strong class="save-amount">${symbol}${yearlyVal}/yr</strong> — save ${save}`;
    }
  }

  btnMonthly?.addEventListener('click', () => {
    period = 'monthly';
    btnMonthly.classList.add('active');
    btnMonthly.setAttribute('aria-pressed', 'true');
    btnYearly?.classList.remove('active');
    btnYearly?.setAttribute('aria-pressed', 'false');
    updatePrices();
  });

  btnYearly?.addEventListener('click', () => {
    period = 'yearly';
    btnYearly.classList.add('active');
    btnYearly.setAttribute('aria-pressed', 'true');
    btnMonthly?.classList.remove('active');
    btnMonthly?.setAttribute('aria-pressed', 'false');
    updatePrices();
  });

  picker?.addEventListener('change', () => {
    currency = (picker.value as 'GBP' | 'EUR' | 'USD');
    updatePrices();
  });

  // Auto-detect currency from locale
  try {
    const locale = navigator.language ?? 'en-GB';
    if (locale.startsWith('en-GB') || locale === 'en-IE') {
      // leave GBP
    } else if (/^(de|fr|es|it|nl|be|at|pt|se|no|da|fi|pl|cs|hu|ro|el)/.test(locale)) {
      currency = 'EUR';
      if (picker) picker.value = 'EUR';
    } else if (!locale.startsWith('en-GB')) {
      // Default non-GB to USD only if definitely not EUR
    }
    updatePrices();
  } catch { /* ignore */ }
</script>
