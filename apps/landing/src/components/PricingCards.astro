---
import { PLAN_META, PLAN_FEATURES, FEATURE_META, PRICES, YEARLY_SAVINGS, type PlanId } from '@plans';

interface Props {
  showToggle?: boolean;
}
const { showToggle = true } = Astro.props;

const planIds: PlanId[] = ['navigation', 'custom'];

// Show top 6 features per plan for cleaner visual
const MAX_FEATURES = 6;
---

<section class="pricing-section below-fold" id="pricing" aria-labelledby="pricing-heading">
  <div class="container">
    {showToggle && (
      <div class="pricing-toggle reveal" role="group" aria-label="Billing period">
        <button id="toggle-monthly" class="toggle-btn active" aria-pressed="true">Monthly</button>
        <button id="toggle-yearly"  class="toggle-btn" aria-pressed="false">
          Yearly
          <span class="toggle-save chip chip-green">Save ~2 months</span>
        </button>
      </div>
    )}

    <div class="currency-select reveal">
      <label for="currency-picker" class="sr-only">Currency</label>
      <select id="currency-picker" class="currency-picker" aria-label="Select currency">
        <option value="GBP">£ GBP</option>
        <option value="EUR">€ EUR</option>
        <option value="USD">$ USD</option>
      </select>
    </div>

    <div class="pricing-grid">
      {planIds.map((planId, idx) => {
        const meta = PLAN_META[planId];
        const prices = PRICES[planId];
        const features = (PLAN_FEATURES[planId] as readonly string[]).slice(0, MAX_FEATURES);
        const isPro = planId === 'navigation';
        return (
          <div class={`pricing-card reveal${meta.highlight ? ' pricing-card--highlight' : ''}`} data-delay={String(idx * 100)}>
            <!-- Badge -->
            {meta.badge && (
              <div class="pricing-badge">{meta.badge}</div>
            )}

            <!-- Plan identity -->
            <div class="pricing-plan-header">
              <div class="pricing-plan-name">{meta.displayName}</div>
              <p class="pricing-tagline">{meta.tagline}</p>
            </div>

            <!-- Price -->
            <div class="pricing-price-block" id={`price-${planId}`} data-plan={planId}>
              {prices.GBP.monthly === null ? (
                <div class="pricing-price">
                  <span class="price-custom">Custom</span>
                </div>
              ) : (
                <div class="pricing-price">
                  <span class="price-currency">£</span>
                  <span class="price-amount" data-gbp-monthly={prices.GBP.monthly} data-gbp-yearly={prices.GBP.yearly}
                    data-eur-monthly={prices.EUR.monthly} data-eur-yearly={prices.EUR.yearly}
                    data-usd-monthly={prices.USD.monthly} data-usd-yearly={prices.USD.yearly}>
                    {prices.GBP.monthly?.toFixed(2)}
                  </span>
                  <span class="price-period">/mo</span>
                </div>
              )}
              {isPro && (
                <div class="pricing-yearly-note" id="save-navigation">
                  £97.00/year — save £22.64 · <strong>VAT included</strong>
                </div>
              )}
              {!isPro && (
                <div class="pricing-yearly-note">
                  Tailored to your fleet size
                </div>
              )}
            </div>

            <!-- CTA -->
            <a href={meta.ctaHref} class={`btn pricing-cta${meta.highlight ? ' btn-primary' : ' btn-secondary'}`}>
              {meta.cta}
            </a>

            <!-- Divider -->
            <div class="pricing-divider"></div>

            <!-- What's included -->
            <div class="pricing-included-label">What's included</div>

            <ul class="pricing-features" aria-label={`Features in ${meta.displayName}`}>
              {features.map(key => (
                <li class="pricing-feature-item">
                  <span class="feature-check-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                      <circle cx="8" cy="8" r="7" fill="rgba(0,194,168,0.12)" stroke="rgba(0,194,168,0.25)" stroke-width="0.75"/>
                      <path d="M5 8l2 2 4-4" stroke="#00C2A8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                  <span>{FEATURE_META[key as keyof typeof FEATURE_META]?.label ?? key}</span>
                </li>
              ))}
            </ul>

            {isPro && (
              <a href="/pricing" class="pricing-see-all">
                See all features →
              </a>
            )}
          </div>
        );
      })}
    </div>

    <p class="pricing-footnote reveal">
      All prices include VAT. Currency selectable above. <strong>Cancel anytime</strong> — no auto-renew, no cancellation fees.
    </p>
  </div>
</section>

<style>
  /* ── Toggle ────────────────────────────────────────────────────── */
  .pricing-toggle {
    display: flex;
    gap: 4px;
    background: var(--surface);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-pill);
    padding: 4px;
    width: fit-content;
    margin-inline: auto;
    margin-bottom: 20px;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    border-radius: var(--r-pill);
    padding: 8px 20px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink-muted);
    cursor: pointer;
    transition: background var(--dur-micro) ease-out,
                color var(--dur-micro) ease-out;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .toggle-btn.active {
    background: var(--brand);
    color: #000;
    font-weight: 600;
  }

  @media (hover: hover) {
    .toggle-btn:not(.active):hover {
      color: var(--ink);
      background: var(--surface-2);
    }
  }

  .toggle-save { font-size: 0.7rem; }

  .currency-select {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  .currency-picker {
    background: var(--surface);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-btn);
    color: var(--ink-muted);
    font-size: 0.875rem;
    padding: 6px 12px;
    cursor: pointer;
    font-family: inherit;
  }

  /* ── Cards grid ───────────────────────────────────────────────── */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 32px;
    align-items: start;
  }

  @media (min-width: 640px) {
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Card ──────────────────────────────────────────────────────── */
  .pricing-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-radius: var(--r-card);
    border: 1px solid var(--glass-brd);
    background: var(--surface);
    padding: 28px 24px;
    transition:
      border-color var(--dur-std) ease,
      box-shadow var(--dur-std) ease,
      background var(--dur-std) ease;
  }

  @media (hover: hover) {
    .pricing-card:hover {
      border-color: rgba(0, 194, 168, 0.2);
    }
  }

  .pricing-card--highlight {
    border-color: rgba(0, 194, 168, 0.25);
    background: linear-gradient(
      160deg,
      rgba(0, 194, 168, 0.05) 0%,
      var(--surface) 60%
    );
    box-shadow: 0 0 0 1px rgba(0, 194, 168, 0.08), 0 8px 32px rgb(0 0 0 / 0.3);
  }

  /* ── Badge ─────────────────────────────────────────────────────── */
  .pricing-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #000;
    background: var(--brand);
    padding: 3px 14px;
    border-radius: var(--r-pill);
  }

  /* ── Plan header ──────────────────────────────────────────────── */
  .pricing-plan-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pricing-plan-name {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink);
  }

  .pricing-tagline {
    font-size: 0.875rem;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  /* ── Price block ──────────────────────────────────────────────── */
  .pricing-price-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-block: 4px;
    border-block: 1px solid rgba(255,255,255,0.06);
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .price-currency {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--ink-muted);
  }

  .price-amount {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
  }

  .price-period {
    font-size: 0.9375rem;
    color: var(--ink-muted);
    margin-left: 4px;
  }

  .price-custom {
    font-family: 'Space Grotesk Variable', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--ink);
  }

  .pricing-yearly-note {
    font-size: 0.75rem;
    color: var(--ink-faint);
  }

  .pricing-yearly-note strong {
    color: var(--brand);
    font-weight: 600;
  }

  /* ── CTA ───────────────────────────────────────────────────────── */
  .pricing-cta {
    width: 100%;
    justify-content: center;
  }

  /* ── Divider + included label ─────────────────────────────────── */
  .pricing-divider {
    height: 1px;
    background: rgba(255,255,255,0.06);
  }

  .pricing-included-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  /* ── Features list ────────────────────────────────────────────── */
  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .pricing-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  .feature-check-icon {
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
  }

  /* ── See all link ────────────────────────────────────────────── */
  .pricing-see-all {
    font-size: 0.875rem;
    color: var(--brand);
    text-decoration: none;
    text-align: center;
    padding-top: 4px;
  }

  .pricing-see-all:hover {
    color: var(--brand-bright);
  }

  /* ── Footnote ────────────────────────────────────────────────── */
  .pricing-footnote {
    font-size: 0.875rem;
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    color: var(--ink-faint);
  }

  .pricing-footnote strong {
    color: var(--brand);
    font-weight: 600;
  }
</style>

<script>
  // ─── Pricing toggle (monthly / yearly) ────────────────────────────
  const btnMonthly = document.getElementById('toggle-monthly');
  const btnYearly  = document.getElementById('toggle-yearly');
  const picker     = document.getElementById('currency-picker') as HTMLSelectElement | null;

  if (!btnMonthly || !btnYearly) { /* static-only fallback */ }

  let period: 'monthly' | 'yearly' = 'monthly';
  let currency: 'GBP' | 'EUR' | 'USD' = 'GBP';

  const currencySymbols: Record<string, string> = { GBP: '£', EUR: '€', USD: '$' };
  const currencyYearlySave: Record<string, string> = { GBP: '£22.64', EUR: '€27.64', USD: '$31.64' };

  function updatePrices() {
    const amounts = document.querySelectorAll<HTMLElement>('.price-amount');
    const currencies = document.querySelectorAll<HTMLElement>('.price-currency');
    const saveEl = document.getElementById('save-navigation');

    amounts.forEach(el => {
      // Data attributes are data-gbp-monthly, data-gbp-yearly, etc. (with hyphen)
      const key = `${currency.toLowerCase()}-${period}` as `${string}-${string}`;
      const val = (el.dataset as Record<string, string | undefined>)[key];
      if (val !== undefined) el.textContent = parseFloat(val).toFixed(2);
    });

    currencies.forEach(el => {
      el.textContent = currencySymbols[currency] ?? '£';
    });

    if (saveEl) {
      const sym = currencySymbols[currency] ?? '£';
      const yearly = { GBP: '97.00', EUR: '116.00', USD: '130.00' }[currency] ?? '97.00';
      const save = currencyYearlySave[currency] ?? '£22.64';
      saveEl.innerHTML = `${sym}${yearly}/year — save ${save} · <strong>VAT included</strong>`;
    }
  }

  btnMonthly?.addEventListener('click', () => {
    period = 'monthly';
    btnMonthly.classList.add('active');
    btnMonthly.setAttribute('aria-pressed', 'true');
    btnYearly?.classList.remove('active');
    btnYearly?.setAttribute('aria-pressed', 'false');
    updatePrices();
  });

  btnYearly?.addEventListener('click', () => {
    period = 'yearly';
    btnYearly.classList.add('active');
    btnYearly.setAttribute('aria-pressed', 'true');
    btnMonthly?.classList.remove('active');
    btnMonthly?.setAttribute('aria-pressed', 'false');
    updatePrices();
  });

  picker?.addEventListener('change', () => {
    currency = (picker.value as 'GBP' | 'EUR' | 'USD');
    updatePrices();
  });

  // Auto-detect currency from locale
  try {
    const locale = navigator.language ?? 'en-GB';
    if (locale.startsWith('en-GB') || locale === 'en-IE') {
      // leave GBP
    } else if (/^(de|fr|es|it|nl|be|at|pt|se|no|da|fi|pl|cs|hu|ro|el)/.test(locale)) {
      currency = 'EUR';
      if (picker) picker.value = 'EUR';
    } else if (!locale.startsWith('en-GB')) {
      // Default non-GB to USD only if definitely not EUR
    }
    updatePrices();
  } catch { /* ignore */ }
</script>
