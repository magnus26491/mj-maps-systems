---
/**
 * RouteLine.astro — "Living Route HUD" signature motif
 *
 * Animated dashed/glowing teal polyline that threads through map backgrounds.
 * Pulses in turn-score colour (green/amber/red) on safety sections.
 * Respects prefers-reduced-motion.
 *
 * Props:
 *   score: 'green' | 'amber' | 'red' | 'teal'  (default: 'teal')
 *   animated: boolean  (default: true)
 *   class: additional CSS classes
 *   width/height: SVG viewBox dimensions (default 300/200)
 */

interface Props {
  score?: 'green' | 'amber' | 'red' | 'teal';
  animated?: boolean;
  class?: string;
  viewBox?: string;
}

const {
  score = 'teal',
  animated = true,
  class: className = '',
  viewBox = '0 0 300 200',
} = Astro.props;

// Score colours
const scoreColors = {
  green:  { stroke: '#10B981', glow: 'rgba(16, 185, 129, 0.4)', pulse: '#10B981' },
  amber:  { stroke: '#F59E0B', glow: 'rgba(245, 158, 11, 0.4)', pulse: '#F59E0B' },
  red:    { stroke: '#EF4444', glow: 'rgba(239, 68, 68, 0.4)', pulse: '#EF4444' },
  teal:   { stroke: '#00C2A8', glow: 'rgba(0, 194, 168, 0.35)', pulse: '#00E8D4' },
};

const color = scoreColors[score];
---

<svg
  class:list={['route-line-svg', animated ? 'route-animated' : '', `route-score-${score}`, className]}
  viewBox={viewBox}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  role="img"
>
  <defs>
    <!-- Glow filter -->
    <filter id="route-glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- Pulse filter for turn-score sections -->
    <filter id="route-pulse" x="-100%" y="-100%" width="300%" height="300%">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- Animated dash pattern -->
    <linearGradient id="route-grad-main" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color={color.stroke} stop-opacity="0.6"/>
      <stop offset="50%" stop-color={color.stroke} stop-opacity="1"/>
      <stop offset="100%" stop-color={color.stroke} stop-opacity="0.6"/>
    </linearGradient>
  </defs>

  <!-- Ambient glow under the line -->
  <path
    d="M 30 160 C 50 160 60 130 80 120 C 100 110 120 90 150 80 C 180 70 200 60 230 90"
    stroke={color.glow}
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
    class="route-glow-path"
  />

  <!-- Main animated route line -->
  <path
    d="M 30 160 C 50 160 60 130 80 120 C 100 110 120 90 150 80 C 180 70 200 60 230 90"
    stroke={color.stroke}
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
    stroke-dasharray="8 6"
    class="route-main-path"
    filter="url(#route-glow)"
  />

  <!-- Start pip -->
  <circle cx="30" cy="160" r="5" fill={color.stroke} class="route-pip route-pip-start"/>

  <!-- End pip with pulse ring -->
  <circle cx="230" cy="90" r="6" fill={color.stroke} class="route-pip route-pip-end"/>
  <circle cx="230" cy="90" r="6" fill="none" stroke={color.pulse} stroke-width="2" class="route-pip-ring" filter="url(#route-pulse)"/>

  <!-- Mid-point stop pips -->
  <circle cx="80" cy="120" r="3.5" fill={color.stroke} opacity="0.6" class="route-stop-pip"/>
  <circle cx="150" cy="80" r="3.5" fill={color.stroke} opacity="0.6" class="route-stop-pip"/>
</svg>

<style>
  .route-line-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* ─── Animations ──────────────────────────────────────────────────── */

  .route-animated .route-main-path {
    stroke-dasharray: 8 6;
    stroke-dashoffset: 0;
    animation: route-dash 1.5s linear infinite;
  }

  .route-animated .route-glow-path {
    animation: route-glow-pulse 2s ease-in-out infinite;
  }

  .route-animated .route-pip-end {
    animation: pip-appear 400ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
               pip-glow 2s ease-in-out infinite 400ms;
  }

  .route-animated .route-pip-ring {
    animation: ring-expand 2s ease-out infinite;
    transform-origin: 230px 90px;
  }

  .route-animated .route-stop-pip {
    animation: pip-fade-in 300ms ease-out forwards;
  }

  .route-animated .route-stop-pip:nth-child(4) {
    animation-delay: 600ms;
  }

  .route-animated .route-stop-pip:nth-child(5) {
    animation-delay: 900ms;
  }

  /* Score colour pulse (amber/red sections) */
  .route-score-amber .route-main-path,
  .route-score-red .route-main-path {
    animation: route-dash 1.5s linear infinite, score-pulse 1.5s ease-in-out infinite;
  }

  @keyframes route-dash {
    to { stroke-dashoffset: -28; }
  }

  @keyframes route-glow-pulse {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1; }
  }

  @keyframes pip-appear {
    from { opacity: 0; transform: scale(0.3); transform-origin: 230px 90px; }
    to   { opacity: 1; transform: scale(1);   transform-origin: 230px 90px; }
  }

  @keyframes pip-glow {
    0%, 100% { filter: drop-shadow(0 0 4px currentColor); }
    50%       { filter: drop-shadow(0 0 8px currentColor); }
  }

  @keyframes ring-expand {
    0%   { r: 6;  opacity: 0.8; }
    100% { r: 20; opacity: 0; }
  }

  @keyframes pip-fade-in {
    from { opacity: 0; r: 2; }
    to   { opacity: 0.6; r: 3.5; }
  }

  @keyframes score-pulse {
    0%, 100% { stroke-opacity: 0.85; }
    50%       { stroke-opacity: 1; }
  }

  /* ─── Reduced motion ──────────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .route-animated .route-main-path,
    .route-animated .route-glow-path,
    .route-animated .route-pip-end,
    .route-animated .route-pip-ring,
    .route-animated .route-stop-pip {
      animation: none;
    }

    .route-animated .route-stop-pip {
      opacity: 0.6;
    }

    .route-animated .route-pip-end {
      transform-origin: 230px 90px;
    }
  }
</style>