---
// Problem → Solution: postcode centroid vs exact pin; dead-end vs turn-around
---

<section class="ps-section below-fold" aria-labelledby="ps-heading">
  <div class="container">
    <div class="section-label reveal">The routing problem others ignore</div>
    <h2 id="ps-heading" class="reveal">Built for how UK deliveries actually work</h2>
    <p class="section-sub reveal">Consumer sat-navs route to a postcode centroid — often 50 metres from the actual gate. MJ Maps routes to the delivery pin, and warns you about what you'll find when you get there.</p>

    <div class="ps-grid">
      <div class="ps-item card reveal">
        <div class="ps-before">
          <div class="ps-label chip chip-red">Before</div>
          <div class="ps-scenario">
            <p class="ps-scenario-title">Postcode centroid routing</p>
            <div class="ps-mockup">
              <svg viewBox="0 0 220 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <!-- Road -->
                <rect x="60" y="0" width="20" height="120" fill="rgba(255,255,255,0.05)" rx="2"/>
                <!-- Centroid pin (wrong) -->
                <circle cx="70" cy="60" r="8" fill="rgba(239,68,68,0.2)" stroke="#EF4444"/>
                <text x="84" y="64" fill="#EF4444" font-size="9" font-family="Inter,sans-serif">Centroid (wrong)</text>
                <!-- Gate (right) -->
                <rect x="100" y="50" width="40" height="20" fill="rgba(34,197,94,0.1)" stroke="#22C55E" stroke-dasharray="3 2" rx="3"/>
                <text x="104" y="63" fill="#22C55E" font-size="8" font-family="Inter,sans-serif">Actual gate</text>
                <line x1="100" y1="60" x2="78" y2="60" stroke="#EF4444" stroke-width="1.5" stroke-dasharray="4 3"/>
                <text x="62" y="90" fill="#8AA0B2" font-size="8" font-family="Inter,sans-serif">~50m off</text>
              </svg>
            </div>
            <p class="ps-desc text-muted">Driver circles the estate, calls the depot, loses 8 minutes per stop.</p>
          </div>
        </div>
      </div>

      <div class="ps-arrow" aria-hidden="true">→</div>

      <div class="ps-item card reveal">
        <div class="ps-after">
          <div class="ps-label chip chip-green">After</div>
          <div class="ps-scenario">
            <p class="ps-scenario-title">what3words gate pin</p>
            <div class="ps-mockup">
              <svg viewBox="0 0 220 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="60" y="0" width="20" height="120" fill="rgba(255,255,255,0.05)" rx="2"/>
                <rect x="100" y="50" width="40" height="20" fill="rgba(34,197,94,0.15)" stroke="#22C55E" rx="3"/>
                <circle cx="120" cy="60" r="6" fill="#22C55E"/>
                <text x="145" y="57" fill="#22C55E" font-size="8" font-family="Inter,sans-serif">///filled.lamp</text>
                <text x="145" y="68" fill="#22C55E" font-size="8" font-family="Inter,sans-serif">.arrive</text>
                <text x="62" y="90" fill="#8AA0B2" font-size="8" font-family="Inter,sans-serif">Exact pin</text>
              </svg>
            </div>
            <p class="ps-desc text-muted">Driver arrives at the right gate, first time, every time.</p>
          </div>
        </div>
      </div>

      <div class="ps-item card reveal">
        <div class="ps-before">
          <div class="ps-label chip chip-red">Before</div>
          <div class="ps-scenario">
            <p class="ps-scenario-title">Dead-end with a lorry</p>
            <div class="ps-mockup dead-end-mockup">
              <svg viewBox="0 0 220 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="40" y="50" width="140" height="20" fill="rgba(255,255,255,0.05)" rx="2"/>
                <rect x="170" y="30" width="20" height="60" fill="rgba(255,255,255,0.05)" rx="2"/>
                <!-- Lorry -->
                <rect x="80" y="53" width="50" height="14" fill="rgba(239,68,68,0.2)" stroke="#EF4444" rx="2"/>
                <text x="88" y="63" fill="#EF4444" font-size="7" font-family="Inter,sans-serif">HGV stuck</text>
                <!-- Wall -->
                <rect x="186" y="35" width="20" height="50" fill="rgba(239,68,68,0.3)"/>
                <text x="190" y="85" fill="#EF4444" font-size="7" font-family="Inter,sans-serif">Wall</text>
              </svg>
            </div>
            <p class="ps-desc text-muted">Van routes into a dead-end. Can't turn around. Blocks traffic.</p>
          </div>
        </div>
      </div>

      <div class="ps-arrow" aria-hidden="true">→</div>

      <div class="ps-item card reveal">
        <div class="ps-after">
          <div class="ps-label chip chip-green">After</div>
          <div class="ps-scenario">
            <p class="ps-scenario-title">Turn-score pre-warning</p>
            <div class="ps-mockup">
              <svg viewBox="0 0 220 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="40" y="50" width="140" height="20" fill="rgba(255,255,255,0.05)" rx="2"/>
                <circle cx="170" cy="60" r="18" fill="rgba(245,158,11,0.15)" stroke="#F59E0B" stroke-dasharray="4 3"/>
                <text x="152" y="56" fill="#F59E0B" font-size="8" font-family="Inter,sans-serif">⚠ Tight</text>
                <text x="150" y="66" fill="#F59E0B" font-size="7" font-family="Inter,sans-serif">turn ahead</text>
                <path d="M 80 60 L 140 60" stroke="#2EE6CE" stroke-width="2.5" stroke-dasharray="5 3" stroke-linecap="round"/>
              </svg>
            </div>
            <p class="ps-desc text-muted">Driver warned 300m before the tight turn. Takes the alternate.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--brand-bright);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    text-align: center;
  }

  .ps-section h2 {
    text-align: center;
    margin-bottom: 12px;
  }

  .section-sub {
    color: var(--ink-muted);
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: 48px;
  }

  .ps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: center;
  }

  @media (min-width: 640px) {
    .ps-grid {
      grid-template-columns: 1fr auto 1fr 1fr auto 1fr;
      gap: 8px;
    }
  }

  @media (min-width: 640px) and (max-width: 900px) {
    .ps-grid {
      grid-template-columns: 1fr auto 1fr;
    }
    .ps-item:nth-child(4),
    .ps-item:nth-child(6) { grid-column: span 1; }
    .ps-arrow:nth-child(5) { grid-column: 2; }
  }

  .ps-arrow {
    font-size: 1.5rem;
    color: var(--ink-faint);
    text-align: center;
    display: none;
  }

  @media (min-width: 640px) {
    .ps-arrow { display: block; }
  }

  .ps-item.card {
    height: 100%;
  }

  .ps-label {
    margin-bottom: 12px;
  }

  .ps-scenario-title {
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
    font-size: 0.9375rem;
  }

  .ps-mockup {
    background: rgba(10,14,20,0.5);
    border-radius: 8px;
    padding: 8px;
    margin-bottom: 12px;
  }

  .ps-desc {
    font-size: 0.875rem;
  }
</style>
