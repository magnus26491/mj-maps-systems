---
// Honest trust bar — no fabricated logos or counts
---

<section class="trust-bar below-fold">
  <div class="container">
    <p class="trust-label text-faint">Built for the realities of UK delivery</p>
    <div class="trust-items">
      <div class="trust-pill reveal">
        <span class="trust-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1.5C4.51 1.5 2.5 3.51 2.5 6c0 3.5 4.5 7 4.5 7s4.5-3.5 4.5-7c0-2.49-2.01-4.5-4.5-4.5z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
            <circle cx="7" cy="6" r="1.5" stroke="currentColor" stroke-width="1.25"/>
          </svg>
        </span>
        <span>OS-accurate UK maps</span>
      </div>
      <div class="trust-pill reveal">
        <span class="trust-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="1.5" y="3" width="8" height="7" rx="1" stroke="currentColor" stroke-width="1.25"/>
            <path d="M9.5 6h1.5l2 3H9.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="4" cy="10.5" r="1" fill="currentColor"/>
            <circle cx="9.5" cy="10.5" r="1" fill="currentColor"/>
          </svg>
        </span>
        <span>HGV to bicycle profiles</span>
      </div>
      <div class="trust-pill reveal">
        <span class="trust-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.25" stroke-dasharray="3 2"/>
            <path d="M7 5v2.5L9 9" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span>Full offline support</span>
      </div>
      <div class="trust-pill reveal">
        <span class="trust-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="3" y="6" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.25"/>
            <path d="M5 6V4.5a2 2 0 0 1 4 0V6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
          </svg>
        </span>
        <span>GDPR compliant</span>
      </div>
      <div class="trust-pill reveal">
        <span class="trust-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1.5L1.5 5v4l5.5 3.5 5.5-3.5V5L7 1.5z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
            <path d="M1.5 5l5.5 3.5L12.5 5" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
          </svg>
        </span>
        <span>UK-founded & operated</span>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    padding-block: 32px;
    border-block: 1px solid var(--glass-brd);
    background: var(--void-2);
  }

  .trust-label {
    text-align: center;
    font-size: 0.875rem;
    color: var(--ink-faint);
    margin-bottom: 24px;
  }

  .trust-items {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    align-items: center;
  }

  .trust-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--glass-brd);
    border-radius: var(--r-pill);
    padding: 8px 16px;
    font-size: 0.9375rem;
    color: var(--ink-muted);
  }

  .trust-icon {
    font-size: 1rem;
  }
</style>
