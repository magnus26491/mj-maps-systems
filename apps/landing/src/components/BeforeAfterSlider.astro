---
/**
 * BeforeAfterSlider.astro — Draggable postcode centroid vs gate-pin comparison
 *
 * Draggable vertical divider comparing blurry postcode-centroid geocoding
 * against sharp gate-pin delivery. Fully keyboard accessible.
 *
 * Props:
 *   beforeSrc: string  — before image URL
 *   afterSrc: string   — after image URL
 *   beforeLabel: string  (default: 'Postcode centroid')
 *   afterLabel: string   (default: 'Gate pin + Plus Code')
 *   initialPosition: 0-100  (default: 50)
 *   class: additional CSS classes
 *
 * Accessibility:
 * - role="slider" on the handle
 * - aria-valuenow, aria-valuemin, aria-valuemax
 * - Arrow key navigation (left/right = ±5%)
 * - Home/End = 0%/100%
 */

interface Props {
  beforeSrc?: string;
  afterSrc?: string;
  beforeLabel?: string;
  afterLabel?: string;
  initialPosition?: number;
  class?: string;
}

const {
  beforeSrc = '/img/before-postcode-centroid.svg',
  afterSrc  = '/img/after-gate-pin.svg',
  beforeLabel = 'Postcode centroid',
  afterLabel  = 'Gate pin + Plus Code',
  initialPosition = 50,
  class: className = '',
} = Astro.props;

const sliderId = `slider-${Math.random().toString(36).slice(2, 8)}`;
---

<div class:list={['ba-slider', className]} id={`ba-${sliderId}`} data-pos={initialPosition}>
  <!-- Images -->
  <div class="ba-images">
    <!-- After (full image underneath) -->
    <div class="ba-after">
      <img
        src={afterSrc}
        alt={afterLabel}
        width="600"
        height="400"
        loading="lazy"
        onerror={`this.src='/img/after-gate-pin.svg'`}
      />
      <span class="ba-label ba-label-after mono">{afterLabel}</span>
    </div>

    <!-- Before (clipped) -->
    <div class="ba-before">
      <img
        src={beforeSrc}
        alt={beforeLabel}
        width="600"
        height="400"
        loading="lazy"
        onerror={`this.src='/img/before-postcode-centroid.svg'`}
      />
      <span class="ba-label ba-label-before mono">{beforeLabel}</span>
    </div>

    <!-- Divider line -->
    <div class="ba-divider" aria-hidden="true">
      <div class="ba-divider-line"></div>
    </div>

    <!-- Handle -->
    <button
      class="ba-handle"
      id={sliderId}
      role="slider"
      aria-label="Drag to compare postcode centroid vs gate pin"
      aria-valuemin={0}
      aria-valuemax={100}
      aria-valuenow={initialPosition}
      aria-valuetext={`${beforeLabel}, ${initialPosition}%`}
      tabindex="0"
    >
      <span class="ba-handle-icon" aria-hidden="true">
        <!-- Drag arrows SVG -->
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7 5 L3 10 L7 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M13 5 L17 10 L13 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 2"/>
        </svg>
      </span>
    </button>
  </div>

  <!-- Screen-reader description -->
  <p class="sr-only">
    Drag the slider left to see the postcode centroid geocoding result (blurry, imprecise),
    or right to see the gate pin result (sharp, exact Plus Code and approach arrow).
  </p>
</div>

<style>
  .ba-slider {
    position: relative;
    width: 100%;
    max-width: 600px;
    border-radius: var(--r-lg);
    overflow: hidden;
    cursor: col-resize;
    user-select: none;
    touch-action: pan-y;
    background: var(--color-surface-1);
    border: 1px solid var(--glass-brd);
    box-shadow: var(--elevation-1);
  }

  .ba-images {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  /* ─── Image layers ─────────────────────────────────────────────────── */

  .ba-after,
  .ba-before {
    position: absolute;
    inset: 0;
  }

  .ba-after img,
  .ba-before img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Before image is clipped by JS-set width */
  .ba-before {
    width: 50%;
    overflow: hidden;
    border-right: none;
    z-index: 2;
  }

  /* ─── Labels ──────────────────────────────────────────────────────── */

  .ba-label {
    position: absolute;
    bottom: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: var(--r-pill);
    background: rgba(10, 12, 16, 0.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    white-space: nowrap;
    pointer-events: none;
  }

  .ba-label-before {
    right: 12px;
    color: var(--ink-faint);
  }

  .ba-label-after {
    left: 12px;
    color: var(--brand-bright);
  }

  /* ─── Divider line ─────────────────────────────────────────────────── */

  .ba-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    z-index: 3;
    pointer-events: none;
  }

  .ba-divider-line {
    width: 2px;
    height: 100%;
    background: var(--brand);
    box-shadow: 0 0 8px rgba(0, 194, 168, 0.5);
  }

  /* ─── Handle ──────────────────────────────────────────────────────── */

  .ba-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--brand);
    border: 3px solid var(--color-base);
    box-shadow: 0 0 0 2px var(--brand), 0 4px 12px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: col-resize;
    transition: transform var(--dur-micro) ease-out,
                box-shadow var(--dur-micro) ease-out;
    touch-action: none;
  }

  .ba-handle:hover,
  .ba-handle:focus-visible {
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 0 0 2px var(--brand-bright), 0 4px 16px rgba(0, 194, 168, 0.4);
  }

  .ba-handle:focus-visible {
    outline: none;
  }

  .ba-handle:active {
    transform: translate(-50%, -50%) scale(0.95);
  }

  .ba-handle-icon {
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Keyboard focus ring override ─────────────────────────────────── */
  .ba-handle:focus-visible {
    outline: 2px solid var(--brand-bright);
    outline-offset: 3px;
  }

  /* ─── Reduced motion ──────────────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    .ba-handle {
      transition: none;
    }
  }
</style>

<script>
  function initSlider(el: HTMLElement) {
    const handle = el.querySelector<HTMLButtonElement>('.ba-handle')!;
    const before = el.querySelector<HTMLElement>('.ba-before')!;
    const divider = el.querySelector<HTMLElement>('.ba-divider')!;

    let pos = parseFloat(el.dataset.pos ?? '50');
    let dragging = false;

    function setPos(p: number) {
      pos = Math.max(0, Math.min(100, p));
      before.style.width = `${pos}%`;
      divider.style.left = `${pos}%`;
      handle.style.left = `${pos}%`;
      handle.setAttribute('aria-valuenow', String(Math.round(pos)));
      handle.setAttribute('aria-valuetext',
        pos < 50 ? `Mostly ${el.dataset.beforeLabel ?? 'before'}` :
        pos > 50 ? `Mostly ${el.dataset.afterLabel ?? 'after'}` :
        'Split evenly'
      );
    }

    // Mouse
    el.addEventListener('mousedown', (e) => {
      dragging = true;
      handle.focus();
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
      if (!dragging) return;
      const rect = el.getBoundingClientRect();
      setPos(((e.clientX - rect.left) / rect.width) * 100);
    });

    window.addEventListener('mouseup', () => { dragging = false; });

    // Touch
    el.addEventListener('touchstart', (e) => {
      dragging = true;
    }, { passive: true });

    el.addEventListener('touchmove', (e: TouchEvent) => {
      if (!dragging) return;
      const rect = el.getBoundingClientRect();
      const touch = e.touches[0];
      setPos(((touch.clientX - rect.left) / rect.width) * 100);
    }, { passive: true });

    el.addEventListener('touchend', () => { dragging = false; });

    // Keyboard
    handle.addEventListener('keydown', (e) => {
      let delta = 0;
      if (e.key === 'ArrowRight' || e.key === 'ArrowUp')   delta = 5;
      if (e.key === 'ArrowLeft'  || e.key === 'ArrowDown')  delta = -5;
      if (e.key === 'Home')  delta = -pos;
      if (e.key === 'End')   delta = 100 - pos;
      if (delta) {
        e.preventDefault();
        setPos(pos + delta);
      }
    });

    // Initial position
    setPos(pos);
  }

  document.querySelectorAll<HTMLElement>('.ba-slider').forEach(initSlider);
</script>