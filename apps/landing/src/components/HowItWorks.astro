---
const steps = [
  {
    num: '01',
    title: 'Enter your stops',
    desc: 'Paste addresses, scan barcodes, or import a manifest. MJ Maps accepts postcodes, what3words references, and Plus Codes — and pins each one to the exact gate or loading bay.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3 L3 9 L3 19 L14 25 L25 19 L25 9 Z" stroke="#2EE6CE" stroke-width="1.5" fill="none"/><text x="14" y="17" text-anchor="middle" fill="#2EE6CE" font-size="10" font-family="'IBM Plex Mono', ui-monospace, monospace">01</text></svg>`,
  },
  {
    num: '02',
    title: 'Route optimises for your vehicle',
    desc: 'The engine scores every segment for your specific van or lorry — weight limits, height barriers, tight turns, road surface, and tidal windows — then finds the fastest safe sequence.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3 L3 9 L3 19 L14 25 L25 19 L25 9 Z" stroke="#2EE6CE" stroke-width="1.5" fill="none"/><text x="14" y="17" text-anchor="middle" fill="#2EE6CE" font-size="10" font-family="'IBM Plex Mono', ui-monospace, monospace">02</text></svg>`,
  },
  {
    num: '03',
    title: 'Drive with real-time alerts',
    desc: 'Turn-by-turn instructions surface green / amber / red score chips for every turn. Deviation triggers an instant reroute. Off-route alerts reach the dispatcher in under 5 seconds.',
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3 L3 9 L3 19 L14 25 L25 19 L25 9 Z" stroke="#2EE6CE" stroke-width="1.5" fill="none"/><text x="14" y="17" text-anchor="middle" fill="#2EE6CE" font-size="10" font-family="'IBM Plex Mono', ui-monospace, monospace">03</text></svg>`,
  },
];
---

<section class="hiw-section below-fold" aria-labelledby="hiw-heading">
  <div class="container">
    <h2 id="hiw-heading" class="reveal">Three steps from stop list to delivered</h2>
    <p class="section-sub reveal">No complex setup. Open the app, add your stops, and go.</p>

    <div class="hiw-steps">
      {steps.map((step, i) => (
        <div class="hiw-step reveal" data-delay={String(i * 100)}>
          <div class="hiw-step-body card">
            <div class="hiw-step-num" aria-hidden="true">{step.num}</div>
            <h3>{step.title}</h3>
            <p class="text-muted">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw-section h2 {
    text-align: center;
    margin-bottom: 12px;
  }

  .hiw-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .hiw-steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
  }

  .hiw-step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (max-width: 767px) {
    .hiw-step {
      padding-left: 52px;
      padding-bottom: 36px;
    }
    .hiw-step:last-child { padding-bottom: 0; }
  }

  /* Human-style numbered circle — not monospace or terminal */
  .hiw-step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0,194,168,0.1);
    border: 1px solid rgba(0,194,168,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-bright);
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-bottom: 16px;
    font-family: 'Space Grotesk Variable', sans-serif;
    position: absolute;
    left: 0;
    top: 20px;
  }

  @media (min-width: 768px) {
    .hiw-step-num {
      position: relative;
      top: auto;
      left: auto;
      margin-bottom: 20px;
    }
  }

  .hiw-step-body {
    width: 100%;
  }

  .hiw-step-body h3 {
    margin-bottom: 8px;
  }
</style>
