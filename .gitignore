# ────────────────────────────────────────────────────────────────────────────────
# MJ Maps Systems — Global .gitignore
# ────────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
*/node_modules/

# Build output
dist/
*/dist/

# Environment
.env
.env.*
!.env.example

# Google Play / Firebase — never commit these
google-services.json
google-play-service-account.json
*.p12
*.keystore

# macOS
.DS_Store

# TypeScript cache
*.tsbuildinfo

# Expo / EAS
.eas/
.expo/

# Vite build output (dispatcher dashboard)
apps/dispatcher-dashboard/dist/

# Compiled .js files that conflict with TypeScript source (dispatcher dashboard)
apps/dispatcher-dashboard/src/*.js
apps/dispatcher-dashboard/src/**/*.js