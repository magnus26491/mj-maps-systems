{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  // Wired services: transitively imported by the Fastify server (services/api/server.ts).
  // All of these are in the request path. "Wired" means at least one file in the
  // request path (server.ts → routes → ...) imports from the service.
  "include": [
    "packages/vehicle-profiles/**/*",
    "packages/subscription-engine/**/*",
    "packages/vehicle-catalogue/**/*",
    "services/api/**/*",
    "services/auth/**/*",
    "services/billing/**/*",
    "services/bridge-engine/**/*",
    "services/cache/**/*",
    "services/cluster-engine/**/*",
    "services/db/**/*",
    "services/dynamic-replan/**/*",
    "services/notifications/**/*",
    "services/osm-client/**/*",
    "services/osm/**/*",
    "services/pin-resolver/**/*",
    "services/property-engine/**/*",
    "services/postcode-resolver/**/*",
    "services/route-completion/**/*",
    "services/route-engine/**/*",
    "services/route-optimizer/**/*",
    "services/storage/**/*",
    "services/stop-precision/**/*",
    "services/traffic-engine/**/*",
    "services/turn-engine/**/*",
    "services/workload/**/*",
    "__tests__/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps/**/*",
    "packages/offline-cache/**/*",
    "packages/offline-sync/**/*",
    "packages/driver-app-shared/**/*",
    "packages/stop-point/**/*",
    "packages/sdk/**/*",
    "packages/vehicle-profiles/__tests__/**/*",
    "legacy/**/*",
    "services/_incubator/**/*",
    "**/__tests__/**/*"
  ]
}
