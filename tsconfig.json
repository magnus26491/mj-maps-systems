{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": [
    "api/**/*",
    "packages/vehicle-profiles/**/*",
    "services/api/**/*",
    "services/cache/**/*",
    "services/db/**/*",
    "services/notifications/**/*",
    "services/route-engine/**/*",
    "services/storage/**/*",
    "services/turn-engine/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps/**/*",
    "packages/offline-cache/**/*",
    "packages/offline-sync/**/*",
    "packages/driver-app-shared/**/*",
    "packages/stop-point/**/*",
    "services/api/__tests__/**/*",
    "packages/vehicle-profiles/__tests__/**/*",
    "services/route-engine/__tests__/**/*",
    "services/turn-engine/__tests__/**/*",
    "services/storage/__tests__/**/*"
  ]
}

