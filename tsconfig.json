{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": ["api/**/*", "services/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "apps/**/*",
    "packages/offline-cache/**/*",
    "packages/sync-queue/**/*",
    "packages/driver-app/**/*",
    "services/sync-queue/**/*"
  ]
}
