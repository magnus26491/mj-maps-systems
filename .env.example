# MJ Maps Systems — Environment Variables
# Copy to .env and fill in values before running locally.
# In Railway: set these in the service Variables panel.
#
# ⚠️  The server boots even when DATABASE_URL is unset (DB-free health check works).
#      Migrations must be run as a Railway pre-deploy step.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Railway uses DATABASE_URL; POSTGRES_URL is the legacy fallback name.
# Both are read — set whichever is convenient.
DATABASE_URL=postgresql://user:password@localhost:5432/mj_maps
POSTGRES_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenStreetMap Overpass API ────────────────────────────────────────────────
# Use public endpoint or self-hosted Overpass instance
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Nominatim Geocoder ────────────────────────────────────────────────────────
# Use OSM public or self-hosted Nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── What3Words (optional but strongly recommended for UK rural stops) ─────────
WHAT3WORDS_API_KEY=your_w3w_api_key_here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create bot via @BotFather, get token
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Dispatcher's Telegram chat ID (get from @userinfobot)
TELEGRAM_DISPATCHER_CHAT_ID=your_chat_id_here

# ── JWT Auth (for user sessions + driver API) ─────────────────────────────────
# Generate a random 64-char hex secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# ── Driver API Key (legacy /api/v1/auth/token endpoint) ───────────────────────
DRIVER_API_KEY=your_driver_api_key_here

# ── PAF (UK Postcode Address File) ──────────────────────────────────────────
# Option A — Postio (pay-per-request, nightly Royal Mail sync, sub-50ms)
# Register free at https://postio.co.uk
POSTIO_KEY=your_postio_api_key_here

# Option B — self-hosted paf-monorepo (zero per-query cost)
# https://github.com/ideal-postcodes/paf-monorepo
# Leave blank if using Postio
PAF_SELF_HOSTED_URL=

# ── Geoapify ─────────────────────────────────────────────────────────────────
# Used by the route optimiser (services/property-engine/) and driver app navigation
# Free tier: 3k req/day at https://geoapify.com
GEOAPIFY_API_KEY=your_geoapify_api_key_here
EXPO_PUBLIC_GEOAPIFY_KEY=your_geoapify_api_key_here

# ── Cloudflare R2 (POD storage) ──────────────────────────────────────────────
# R2 is S3-compatible — use @aws-sdk/client-s3 for uploads
# Dashboard: https://dash.cloudflare.com → R2 → Manage R2 → API Tokens
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mj-maps-pod
R2_PUBLIC_URL=https://pod.mj-maps.com

# ── Stripe Billing ──────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Create product: "MJ Maps Pro" — Recurring, £9.99/month GBP
# Webhook: stripe listen --forward-to localhost:PORT/api/v1/billing/webhook
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
APP_URL=mjmaps://
