# MJ Maps Systems — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─── Redis ───────────────────────────────────────────────────────────────────
# Railway Redis plugin provides this automatically in production
REDIS_URL=redis://localhost:6379

# ─── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Dispatcher group/channel chat ID (get via @userinfobot)
TELEGRAM_DISPATCHER_CHAT_ID=-1001234567890

# ─── Overpass (optional — defaults to public mirrors) ────────────────────────
# Uncomment to use a private Overpass instance
# OVERPASS_PRIMARY_URL=https://your-overpass-instance.com/api/interpreter

# ─── Auth (add when implementing driver auth) ─────────────────────────────────
# JWT_SECRET=change-me-in-production
# API_KEY=change-me-in-production
