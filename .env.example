# MJ Maps Systems — Environment Variables
# Copy to .env and fill in values before running locally.
# In Railway: set these in the service Variables panel.
#
# ⚠️  The server boots even when DATABASE_URL is unset (DB-free health check works).
#      Migrations must be run as a Railway pre-deploy step.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Railway uses DATABASE_URL; POSTGRES_URL is the legacy fallback name.
# Both are read — set whichever is convenient.
DATABASE_URL=postgresql://user:password@localhost:5432/mj_maps
POSTGRES_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Routing Engines (Stage 2) ────────────────────────────────────────────────
# All three are optional. When unset the server falls back to its TypeScript
# Haversine matrix + nearest-neighbour sequencer — functionally correct but
# slower and less accurate than the real engines.
# Run scripts/prepare-osm.sh + docker compose -f docker-compose.dev.yml up
# to start all three locally.
#
# ⚠️  Production: host OSRM + Valhalla on a dedicated server (Railway add-on
#     or a separate VPS). They need ~4 GB RAM each for Great Britain data.

# OSRM — fast N×N duration/distance matrix
# docker-compose.dev.yml starts it at localhost:5000
OSRM_URL=

# Valhalla — truck/van routing + turn-by-turn maneuvers
# docker-compose.dev.yml starts it at localhost:8002
VALHALLA_URL=

# OR-Tools Python sidecar — VRPTW solver
# docker-compose.dev.yml starts it at localhost:8080
ROUTE_SOLVER_URL=

# ── OpenStreetMap Overpass API ────────────────────────────────────────────────
# Use public endpoint or self-hosted Overpass instance
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── Nominatim Geocoder ────────────────────────────────────────────────────────
# Use OSM public or self-hosted Nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── What3Words (optional but strongly recommended for UK rural stops) ─────────
WHAT3WORDS_API_KEY=your_w3w_api_key_here

# ── OS Places API (Stage 3: UPRN-level door pin resolution) ──────────────────
# ⚠️  Register at https://osdatahub.os.uk/ → create a project → enable OS Places API
# Used by services/geocoding/os-places-client.ts to resolve UK postcodes to
# UPRN-keyed address candidates and precise door-level coordinates.
# Falls back to Nominatim when unset — less accurate but no key needed.
OS_PLACES_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create bot via @BotFather, get token
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Dispatcher's Telegram chat ID (get from @userinfobot)
TELEGRAM_DISPATCHER_CHAT_ID=your_chat_id_here

# ── JWT Auth (for user sessions + driver API) ─────────────────────────────────
# Generate a random 64-char hex secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# ── Driver API Key (legacy /api/v1/auth/token endpoint) ───────────────────────
DRIVER_API_KEY=your_driver_api_key_here

# ── PAF (UK Postcode Address File) ──────────────────────────────────────────
# Option A — Postio (pay-per-request, nightly Royal Mail sync, sub-50ms)
# Register free at https://postio.co.uk
POSTIO_KEY=your_postio_api_key_here

# Option B — self-hosted paf-monorepo (zero per-query cost)
# https://github.com/ideal-postcodes/paf-monorepo
# Leave blank if using Postio
PAF_SELF_HOSTED_URL=

# ── Geoapify ─────────────────────────────────────────────────────────────────
# Used by the route optimiser (services/property-engine/) and driver app navigation
# Free tier: 3k req/day at https://geoapify.com
GEOAPIFY_API_KEY=your_geoapify_api_key_here
EXPO_PUBLIC_GEOAPIFY_KEY=your_geoapify_api_key_here

# ── Cloudflare R2 (POD storage) ──────────────────────────────────────────────
# R2 is S3-compatible — use @aws-sdk/client-s3 for uploads
# Dashboard: https://dash.cloudflare.com → R2 → Manage R2 → API Tokens
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mj-maps-pod
R2_PUBLIC_URL=https://pod.mj-maps.com

# ── Stripe Billing ──────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Create product: "MJ Maps Pro" — Recurring, £9.99/month GBP
# Webhook: stripe listen --forward-to localhost:PORT/api/v1/billing/webhook
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
APP_URL=mjmaps://

# ── MapTiler (build-time only — baked into landing page images) ──────────────────
# Used by scripts/fetch-maps.ts (landing page only, NOT runtime).
# Free tier: 100k tile requests/month. Register at https://maptiler.com
# Bakes real static map renders into apps/landing/public/img/ during Docker build.
# When absent, the committed SVG fallbacks are used — no runtime key needed.
MAPTILER_KEY=
